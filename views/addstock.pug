extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .container(style='max-width: 750px;')

      h3.text-center.fw-bold.text-white.mb-4
        u STOCK REGISTRATION

      if error
        .alert.alert-danger= error

      form#addStockForm(action='/add_stock' method='post' enctype="multipart/form-data")

        .row.g-3.mb-3
          .col-md-6
            label.form-label.text-white Product Name
            input#productName.form-control(name='productName' type='text' placeholder='Enter Product Name')
          .col-md-6
            label.form-label.text-white Product Type
            select.form-select(name='productType')
              option(value='') Choose option below
              option(value='Building Materials') Building Materials
              option(value='Hand Tools') Hand Tools
              option(value='Power Tools') Power Tools
              option(value='Plumbing Supplies') Plumbing Supplies
              option(value='Electrical Supplies') Electrical Supplies
              option(value='Paint & Finishing Materials') Paint & Finishing Materials
              option(value='Doors, Windows & Fittings') Doors, Windows & Fittings
              option(value='Carpentry') Carpentry
              option(value='Fasteners & Fixings') Fasteners & Fixings
              option(value='Safety Equipment') Safety Equipment

        .row.g-3.mb-3
          .col-md-6
            label.form-label.text-white Quantity
            input#quantity.form-control(name='quantity' type='number' placeholder='0')
          .col-md-6
            label.form-label.text-white Unit of Measure
            select.form-select(name='unitOfMeasure')
              option(value='') Choose option below
              option(value='kg') Kilogram (kg)
              option(value='g') Gram (g)
              option(value='pc') Piece(s)
              option(value='bg') Bag(s)
              option(value='crt') Carton
              option(value='t') Box
              option(value='ltr') Litre (L)
              option(value='ml') Millilitre (ml)

        .row.g-3.mb-3
          .col-md-6
            label.form-label.text-white Supplier Name
            input#supplierName.form-control(name='supplierName' type='text' placeholder='Enter name here')
          .col-md-6
            label.form-label.text-white Phone Number
            input#phoneNumber.form-control(name='phoneNumber' type='tel' placeholder='07XXXXXXXX')

        .row.g-3.mb-3
          .col-md-6
            label.form-label.text-white Email
            input#email.form-control(name='email' type='email' placeholder='youremail@example.com')
          .col-md-6
            label.form-label.text-white Cost Price (UGX)
            input#costPrice.form-control(name='costPrice' type='number')

        .row.g-3.mb-3
          .col-md-6
            label.form-label.text-white Selling Price (UGX)
            input#sellingPrice.form-control(name='sellingPrice' type='number')
          .col-md-6
            label.form-label.text-white Comment
            input#comment.form-control(name='comment' type='text')

        .row.g-3.mb-4
          .col-md-6
            label.form-label.text-white Item Image
            input#itemImage.form-control(name='itemImage' type='file')

        .d-flex.justify-content-center.mt-2
          button.btn.btn-warning.px-5(type='submit')
            i.fas.fa-plus.me-2
            | Add Stock

  script(src='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.js')
  script.
    document.getElementById("addStockForm").addEventListener("submit", function(e) {
      const phone = document.getElementById("phoneNumber").value.trim();
      let valid = true;

      document.querySelectorAll(".validation-error").forEach(function(el) { el.remove(); });
      document.querySelectorAll(".is-invalid").forEach(function(el) { el.classList.remove("is-invalid"); });

      if (!/^07\d{8}$/.test(phone)) {
        valid = false;
        showError("phoneNumber", "Phone number must be 10 digits and start with 07");
      }

      if (!valid) e.preventDefault();
    });

    function showError(fieldId, message) {
      const field = document.getElementById(fieldId);
      if (!field) return;
      const error = document.