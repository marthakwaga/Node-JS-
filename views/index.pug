doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  meta(http-equiv='x-ua-compatible' content='ie=edge')
  title HOMEPAGE
  // MDB icon
  link(rel='icon' href='img/mdb-favicon.ico' type='image/x-icon')
  // Font Awesome
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css')
  // Google Fonts Roboto
  link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap')
  // MDB
  link(href='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/mdb.min.css')
  link(rel='stylesheet' href='/css/nyondo.css')
  link(rel='stylesheet' href='/css/supplier-registration.css')
// Background image
#intro-example.p-5.text-center.bg-image
  // NAVIGATION BAR
  nav.navbar.navbar-expand-lg.bg-white.fixed-top
    // Container wrapper
    .container-fluid
      // Toggle button
      button.navbar-toggler(data-mdb-collapse-init='' type='button' data-mdb-target='#navbarLeftAlignExample' aria-controls='navbarLeftAlignExample' aria-expanded='false' aria-label='Toggle navigation')
        i.fas.fa-bars
      // Collapsible wrapper
      #navbarLeftAlignExample.collapse.navbar-collapse
        // Left links
        ul.navbar-nav.me-auto.mb-2.mb-lg-0
          li.nav-item
            a.nav-link.active(aria-current='page' href='#') Home
          li.nav-item
            a.nav-link(href='#') Visit Us
          // Navbar dropdown
          li.nav-item.dropdown
            a#navbarDropdown.nav-link.dropdown-toggle(data-mdb-dropdown-init='' href='#' role='button' aria-expanded='false')
              | More
            // Dropdown menu
            ul.dropdown-menu(aria-labelledby='navbarDropdown')
              li
                a.dropdown-item(href='#') Get in Touch
              li
                a.dropdown-item(href='#') Our Products
              li
                hr.dropdown-divider
              li
                a.dropdown-item(href='#') About Us
        // Left links
        // Right icon
        div
          a#navbarDropdownMenuLink.link-secondary.me-3.dropdown-toggle.hidden-arrow(data-mdb-dropdown-init='' href='#' role='button' aria-expanded='false')
        // END OF RIGHT ICON
      // Collapsible wrapper
    // Container wrapper
  // BACKGROUD IMAGE
  .mask.mask-custom(style='background-color: rgba(25, 12, 36, 0.7);')
    .d-flex.justify-content-center.align-items-center.h-100
      .text-white
        h1.mb-3 WELCOME TO NYONDO GENERAL HARDWARE
        h5.mb-4 Supplying Every Step of Your Build!
        a.btn.btn-outline-light.btn-lg.m-2.custome-btn(data-mdb-ripple-init='' href='login.html' role='button' rel='nofollow' target='_blank') LOGIN
        a.btn.btn-outline-light.btn-lg.m-2.custome-btn(data-mdb-ripple-init='' href='signup.html' target='_blank' role='button') Don&apos;t have an account? SIGN UP
// Background image
// FOOTER WITH COPYRIGHT
div
  footer.text-white.text-lg-start(col-md-12='' mb-0='' style='background-color: #23242a;')
    | &copy; 2026 Copyright:
    a.text-white(;='' href='https://mdbootstrap.com/') NyondoGeneralHardware.com
