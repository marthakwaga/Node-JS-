extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    h1.text-white.fw-bold.mb-4 👔 Manager Dashboard

    // Metrics
    .row.g-3.mb-5
      .col-md-3
        .card.border-success.shadow-sm.bg-white.bg-opacity-90
          .card-body
            h5.text-success.fw-bold Total Stock Value
            h3.fw-bold UGX #{totalStockValue ? totalStockValue.toLocaleString() : '0'}

      .col-md-3
        .card.border-warning.shadow-sm.bg-white.bg-opacity-90
          .card-body
            h5.text-warning.fw-bold.fw-bold Low Stock Items
            h3.fw-bold.text-warning= lowStockCount || '0'

      .col-md-3
        .card.border-info.shadow-sm.bg-white.bg-opacity-90
          .card-body
            h5.text-info.fw-bold Today's Sales
            h3.fw-bold UGX #{todayRevenue ? todayRevenue.toLocaleString() : '0'}
            small.text-muted= transactionCount + ' transactions'
    // Low Stock & Quick Actions
    .row
      .col-lg-6.mb-4
        h5.fw-bold.text-warning.fw-bold ⚠️ Low Stock Alerts
        .list-group
          if lowStockItems.length > 0
            each item in lowStockItems
              .list-group-item.d-flex.justify-content-between.align-items-center.text-white
                | #{item.productName}
                - var badgeClass = item.quantity < 5 ? 'bg-danger' : 'bg-warning'
                span.badge(class=badgeClass)= item.quantity + ' ' + (item.unitOfMeasure || '') + ' left'
          else
            .list-group-item.text-muted All stock levels are healthy

      .col-lg-6.mb-4
        h5.fw-bold.text-white.fw-bold ⚡ Quick Actions
        .row.g-3
          .col-6
            a.btn.btn-success.w-100.py-3(href='/add_stock') Register Stock
          .col-6
            a.btn.btn-success.w-100.py-3(href='/addsale') Record Sale
          .col-6
            a.btn.btn-info.w-100.py-3(href='/deposit') Manage Deposits
          .col-6
            a.btn.btn-warning.w-100.py-3(href='/reports') View Reports

    // Recent Activity
    h5.fw-bold.text-white.mt-4 Recent Activity
    .table-responsive
      table.table.table-hover.bg-white.bg-opacity-90
        thead
          tr
            th.fw-bold Date
            th.fw-bold Type
            th.fw-bold Details
            th.text-end.fw-bold Value
        tbody
          if recentSales.length > 0
            each sale in recentSales
              tr
                td= new Date(sale.createdAt).toLocaleDateString()
                td
                  span.badge.bg-success Sale
                td= sale.customerName + ' — ' + sale.items.length + ' item(s)'
                td.text-end.fw-bold= 'UGX ' + sale.totalAmount.toLocaleString()
          if recentStock.length > 0
            each stock in recentStock
              tr
                td= new Date(stock.dateRecieved).toLocaleDateString()
                td
                  span.badge.bg-info Stock In
                td= stock.productName + ' from ' + stock.supplierName
                td.text-end.fw-bold= 'UGX ' + ((stock.quantity || 0) * (stock.costPrice || 0)).toLocaleString()
          if recentSales.length === 0 && recentStock.length === 0
            tr
              td(colspan='4').text-center.text-muted No recent activity

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    const dateEl = document.getElementById('currentDate');
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('en-UG', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
      });
    }