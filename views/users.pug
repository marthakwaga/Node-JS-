extends layout

block content
        // Main Content
        .flex-grow-1.d-flex.flex-column(style='overflow: hidden;')
          .p-4.flex-grow-1.overflow-auto
            .container-fluid
              .d-flex.justify-content-between.align-items-center.mb-4
                h2.text-white
                  i.fas.fa-users.me-2
                  | System Users

                if user && user.userrole === 'admin'
                  button.btn.btn-success.btn-lg(onclick='showRegisterForm()')
                    i.fas.fa-user-plus.me-2
                    | Add New User

              // Success / Error Message Area
              #alertBox(style='display: none;')

              // ==================== REGISTER NEW USER FORM ====================
              if user && user.userrole === 'admin'
                #registerFormSection.card.mb-5(style='display: none;')
                  .card-header.bg-success.text-white
                    h5 Add New System User
                  .card-body
                    form#newUserForm
                      .row.g-3
                        .col-md-6
                          label.form-label Full Name
                          input#newFullName.form-control(type='text' required)
                        .col-md-6
                          label.form-label Username / Phone Number
                          input#newUsername.form-control(type='text' placeholder='0782xxxxxx' required)
                        .col-md-6
                          label.form-label Password
                          input#newPassword.form-control(type='password' required)
                        .col-md-6
                          label.form-label User Role
                          select#newRole.form-select(required)
                            option(value='') Select Role
                            option(value='sales') Sales Attendant
                            option(value='manager') Store Manager
                            option(value='admin') Administrator
                      .mt-4
                        button.btn.btn-success.px-4(type='button' onclick='createNewUser()') Create User
                        button.btn.btn-secondary.ms-3(type='button' onclick='hideRegisterForm()') Cancel

              // Users List
              .card
                .card-body
                  .table-responsive
                    table.table.table-hover.align-middle
                      thead.table-dark
                        tr
                          th Full Name
                          th Username / Phone
                          th Role
                          th Status
                          th Created On
                          if user && user.userrole === 'admin'
                            th Actions
                      tbody#usersBody

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')

  script.
    let usersData = [];

    function showAlert(message, type = 'success') {
      const alertBox = document.getElementById('alertBox');
      alertBox.style.display = 'block';
      alertBox.className = `alert alert-${type} alert-dismissible fade show`;
      alertBox.innerHTML = `
        ${message}
        <button type="button" class="btn-close" onclick="this.parentElement.style.display='none'"></button>
      `;
      // Auto hide after 5 seconds
      setTimeout(() => {
        alertBox.style.display = 'none';
      }, 5000);
    }

    async function loadUsers() {
      try {
        const res = await fetch('/user_reg');
        usersData = await res.json();
        renderUsers();
      } catch (err) {
        console.error(err);
        document.getElementById('usersBody').innerHTML = `<tr><td colspan="6" class="text-center text-danger py-4">Failed to load users</td></tr>`;
      }
    }

    function renderUsers() {
      const tbody = document.getElementById('usersBody');
      tbody.innerHTML = '';

      usersData.forEach(user => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td><strong>${user.fullname || user.name}</strong></td>
          <td>${user.username || user.phone}</td>
          <td>
            <span class="badge ${user.userrole === 'admin' ? 'bg-danger' : user.userrole === 'manager' ? 'bg-primary' : 'bg-success'}">
              ${user.userrole}
            </span>
          </td>
          <td><span class="badge bg-success">Active</span></td>
          <td>${new Date(user.createdAt || Date.now()).toLocaleDateString()}</td>
          ${user.userrole === 'admin' ? `
            <td>
              <button onclick="deleteUser('${user._id}')" class="btn btn-sm btn-outline-danger">Delete</button>
            </td>` : '<td></td>'}
        `;
        tbody.appendChild(row);
      });
    }

    function showRegisterForm() {
      document.getElementById('registerFormSection').style.display = 'block';
      // Clear previous form
      document.getElementById('newUserForm').reset();
    }

    function hideRegisterForm() {
      document.getElementById('registerFormSection').style.display = 'none';
    }

    async function createNewUser() {
      const data = {
        fullname: document.getElementById('newFullName').value.trim(),
        username: document.getElementById('newUsername').value.trim(),
        password: document.getElementById('newPassword').value,
        userrole: document.getElementById('newRole').value
      };

      if (!data.fullname || !data.username || !data.password || !data.userrole) {
        return showAlert("Please fill all required fields", "danger");
      }

      try {
        const res = await fetch('/users/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        if (res.ok) {
          showAlert("✅ User created successfully!", "success");
          hideRegisterForm();
          loadUsers(); // Refresh user list
        } else {
          showAlert(result.message || "Failed to create user", "danger");
        }
      } catch (err) {
        console.error(err);
        showAlert("Network error. Please try again.", "danger");
      }
    }

    function deleteUser(id) {
      if (confirm("Delete this user permanently?")) {
        fetch(`/users/${id}`, { method: 'DELETE' })
          .then(res => res.json())
          .then(() => {
            showAlert("User deleted successfully", "success");
            loadUsers();
          })
          .catch(() => showAlert("Failed to delete user", "danger"));
      }
    }

    // Initialize
    window.onload = loadUsers;