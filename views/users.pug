extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .container-fluid

      .d-flex.justify-content-between.align-items-center.mb-4
        h2.text-white
          i.fas.fa-users.me-2
          | System Users
        if user && user.userRole === 'admin'
          a.btn.btn-success.btn-lg(href='/user_reg')
            i.fas.fa-user-plus.me-2
            | Add New User

      #alertBox(style='display:none;')

      // Users Table
      .card
        .card-body
          .table-responsive
            table.table.table-hover.align-middle
              thead.table-dark
                tr
                  th Full Name
                  th Phone Number
                  th NIN
                  th Role
                  th Status
                  th Created On
                  if user && user.userRole === 'admin'
                    th Actions
              tbody#usersBody
                tr
                  td(colspan='7').text-center.text-muted Loading users...

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    let usersData = [];

    function showAlert(message, type) {
      const alertBox = document.getElementById("alertBox");
      alertBox.style.display = "block";
      alertBox.className = "alert alert-" + type + " alert-dismissible fade show";
      alertBox.innerHTML = message + "<button type=\"button\" class=\"btn-close\" onclick=\"this.parentElement.style.display='none'\"></button>";
      setTimeout(function() { alertBox.style.display = "none"; }, 5000);
    }

    async function loadUsers() {
      try {
        const res = await fetch("/users/api");
        usersData = await res.json();
        renderUsers();
      } catch (err) {
        console.error(err);
        document.getElementById("usersBody").innerHTML = "<tr><td colspan=\"7\" class=\"text-center text-danger py-4\">Failed to load users</td></tr>";
      }
    }

    function renderUsers() {
      const tbody = document.getElementById("usersBody");
      tbody.innerHTML = "";

      if (!usersData.length) {
        tbody.innerHTML = "<tr><td colspan=\"7\" class=\"text-center text-muted py-4\">No users found</td></tr>";
        return;
      }

      usersData.forEach(function(u) {
        const roleMap = {
          "admin": { label: "Admin", badge: "bg-danger" },
          "manager": { label: "Store Manager", badge: "bg-primary" },
          "attendant": { label: "Sales Attendant", badge: "bg-success" }
        };
        const role = roleMap[u.userRole] || { label: u.userRole || "Unknown", badge: "bg-secondary" };

        const row = document.createElement("tr");
        row.innerHTML = `
          <td><strong>${u.fullName || "-"}</strong></td>
          <td>${u.phoneNumber || "-"}</td>
          <td><code>${u.NIN || "-"}</code></td>
          <td><span class="badge ${role.badge}">${role.label}</span></td>
          <td><span class="badge bg-success">Active</span></td>
          <td>${new Date(u.createdAt).toLocaleDateString()}</td>
          <td>
            <button onclick="deleteUser('${u._id}')" class="btn btn-sm btn-outline-danger">
              <i class="fas fa-trash me-1"></i>Delete
            </button>
          </td>`;
        tbody.appendChild(row);
      });
    }

    async function deleteUser(id) {
      if (!confirm("Delete this user permanently?")) return;
      try {
        const res = await fetch("/users/" + id, { method: "DELETE" });
        const result = await res.json();
        if (res.ok) {
          showAlert("User deleted successfully", "success");
          loadUsers();
        } else {
          showAlert(result.message || "Failed to delete user", "danger");
        }
      } catch (err) {
        showAlert("Network error. Please try again.", "danger");
      }
    }

    window.onload = loadUsers;