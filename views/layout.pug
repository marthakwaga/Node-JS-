doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Dashboard - Nyondo General Hardware
    link(href='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css' rel='stylesheet')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
    link(rel='stylesheet' href='/css/mdb.min.css')
    link(rel='stylesheet' href='/css/nyondo.css')
  .bg-image.min-vh-100.d-flex(style="background-image: url('https://images.pexels.com/photos/4312849/pexels-photo-4312849.jpeg');")
    // Dark Overlay
    .mask.mask-custom.flex-grow-1.d-flex(style='background-color: rgba(25, 12, 36, 0.75);')
      // SIDEBAR
      nav.sidebar.p-3.text-white.flex-shrink-0.overflow-auto(style='width: 260px; background: rgba(176, 141, 176, 0.301); color: #333; box-shadow: 2px 0 10px rgba(0,0,0,0.15);')
        .logo.mx-auto.mb-4.text-center(style="background-image: url('/images/logo.png'); \
        width: 140px; height: 140px; \
        background-size: contain; background-repeat: no-repeat;")
        ul.nav.flex-column
          if user 
            li.nav-item
              a.nav-link.text-white(href='/addsale')
                i.fas.fa-shopping-cart
                |  Sales
            li.nav-item
              a.nav-link.text-white(href='/products')
                i.fas.fa-boxes
                |  Products
            if user.userRole === 'admin'
              li.nav-item
                a.nav-link.text-white(href='/add_stock')
                  i.fas.fa-truck-loading
                  |  Stock In
              li.nav-item
                a.nav-link.text-white(href='/deposit')
                  i.fas.fa-hand-holding-usd
                  |  Deposit Scheme
              li.nav-item
                a.nav-link.text-white(href='/supplier')
                  i.fas.fa-users
                  |  Suppliers
              li.nav-item
                a.nav-link.text-white(href='/reports')
                  i.fas.fa-chart-bar
                  |  Reports
            if user.userRole ==='attendant'
              li.nav-item
                a.nav-link.text-white.active(href='/sales_dash')
                  i.fas.fa-tachometer-alt
                  |  My Dashboard
              li.nav-item
                a.nav-link.text-white(href='add-sale.html')
                  i.fas.fa-plus-circle
                  |  New Sale
              li.nav-item
                a.nav-link.text-white(href='sales.html')
                  i.fas.fa-shopping-cart
                  |  Today&apos;s Sales
              li.nav-item
                a.nav-link.text-white(href='products.html')
                  i.fas.fa-boxes
                  |  Products
              li.nav-item
                a.nav-link.text-white(href='deposits.html')
                  i.fas.fa-hand-holding-usd
                  |  Deposits
            if user.userRole ==='manager'
              li.nav-item
                a.nav-link.active(href='manager-dashboard.html')
                  i.fas.fa-tachometer-alt
                  |  Dashboard
              li.nav-item
                a.nav-link(href='/products')
                  i.fas.fa-boxes
                  |  Products 
              li.nav-item
                a.nav-link(href='/add_stock')
                  i.fas.fa-truck-loading
                  |  Stock In
              li.nav-item
                a.nav-link(href='/addsale')
                  i.fas.fa-shopping-cart
                  |  Sales
              li.nav-item
                a.nav-link(href='/deposit')
                  i.fas.fa-hand-holding-usd
                  |  Deposit Scheme
              li.nav-item
                a.nav-link(href='/supplier')
                  i.fas.fa-users
                  |  Suppliers
              li.nav-item
                a.nav-link(href='/reports')
                  i.fas.fa-chart-bar
                  |  Reports
  
            .mt-auto.pt-4
              a.btn.btn-outline-warning.w-100(href='/logout')
                i.fas.fa-sign-out-alt
                |  Logout
      block content