doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  meta(http-equiv='x-ua-compatible' content='ie=edge')
  title Supplier Credit
  link(rel='icon' href='img/mdb-favicon.ico' type='image/x-icon')
  // Font Awesome
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css')
  // Google Fonts Roboto
  link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap')
  // MDB
  link(href='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/mdb.min.css')
  link(rel='stylesheet' href='/css/nyondo.css')
  link(rel='stylesheet' href='/css/customstyles.css')
// Background image
#intro-example.p-5.text-center.bg-image(style="background-image: url('https://images.pexels.com/photos/4312849/pexels-photo-4312849.jpeg');")
  
  // BACKGROUD IMAGE
  .mask.mask-custom(style='background-color: rgba(25, 12, 36, 0.7);')
    .d-flex.justify-content-center.align-items-center.h-100
      .d-flex
        nav.sidebar.p-3.text-white(style='width: 260px; background: rgb(180, 167, 180);')
          .logo.bg-white.p-4.rounded.shadow.mx-auto
          // Same sidebar as stock-in.html
          hr
          ul.nav.flex-column
            li.nav-item
              a.nav-link.text-white(href='dashboard.html')
                i.fas.fa-tachometer-alt
                |  Dashboard
            li.nav-item
              a.nav-link.text-white(href='stock-in.html')
                i.fas.fa-truck-loading
                |  Stock In
            li.nav-item
              a.nav-link.text-white.active(href='suppliercredit.pug')
                i.fas.fa-users
                |  Suppliers
            // Add other links similarly
          hr
          button.btn.btn-outline-light.w-100(onclick='logout()') Logout
        // FORM
        form(action='/suppliercredit' method='post')
          .main-content.flex-grow-1.p-4(style='background-color:ghostwhite;')
            h2(data-translate='suppliers') Supplier Credit Management
            .card.mb-4
              .card-body
                h5 Current Supplier Credit
                table.table.table-hover
                  thead.table-dark
                    tr
                      th Supplier Name
                      th Amount Owed (UGX)
                      th Due Date
                      th Status
                      th Action
                  tbody
                    tr
                      td Factory Depot Uganda Ltd
                      td.text-danger.fw-bold 12,450,000
                      td 2026-05-15
                      td
                        span.badge.bg-warning Pending
                      td
                        button.btn.btn-sm.btn-outline-primary Record Payment
                    tr
                      td Steel Masters Ltd
                      td.text-success 0
                      td -
                      td
                        span.badge.bg-success Cleared
                      td
            button.btn.btn-success(data-bs-toggle='modal' data-bs-target='#addSupplierModal') + Add New Supplier
        // Add Supplier Modal pop up
        #addSupplierModal.modal.fade
          .modal-dialog
            .modal-content
              .modal-header
                h5 Add New Supplier
              .modal-body
                input.form-control.mb-3(name='supplierName' type='text' placeholder='Supplier Name')
                input.form-control.mb-3(name='phoneNumber' type='text' placeholder='Contact Phone')
                input.form-control(name='creditAmount' type='number' placeholder='Credit Amount')
              .modal-footer
                button.btn.btn-secondary(data-bs-dismiss='modal') Cancel
                button.btn.btn-success Save Supplier
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
        script(src='js/app.js')
        script(src='js/translations.js')
