extends layout

block content
  .container.mt-4( style='max-width: 600px; height: 100vh; overflow-y: auto;')
    .card.shadow-lg
      .card-body.p-5

        // Header with Logo
        .text-center.mb-4
          if logoPath
            img(src=logoPath alt="Nyondo General Hardware" style="height: 80px; width: auto;")
          else
            h2.text-warning Nyondo General Hardware

          h4.mt-2.text-dark Suppling Every Step of Your Build!

        hr

        .row.mb-4
          .col-12.col-md-6
            strong Sale ID: 
            span #{sale._id}
          .col-md-6.text-end
            strong Date: 
            span #{new Date(sale.createdAt).toLocaleDateString()}

        .row.mb-4
          .col-12.col-md-6
            strong Representative: 
            span #{sale.representative}
          .col-12.col-md-6
            strong Customer Phone: 
            span #{sale.customerPhone}

        if sale.distance
          p 
            strong Distance: 
            | #{sale.distance} km

        hr

        h5.mb-3 Items Purchased
        table.table.table-bordered
          thead.table-dark
            tr
              th Product
              th.text-center Qty
              th.text-end Unit Price
              th.text-end Total
          tbody
            each item in sale.items
              tr
                td #{item.name}
                td.text-center #{item.quantity}
                td.text-end UGX #{Number(item.unitPrice || 0).toLocaleString()}
                td.text-end.fw-bold UGX #{Number(item.amount || 0).toLocaleString()}

        hr

        .row
      
          .col-md-6.text-end
            h5 Grand Total
            h2.text-success UGX #{Number(sale.amountPaid || 0).toLocaleString()}

            if sale.transportCost > 0
              small.text-muted Transport Included: UGX #{Number(sale.transportCost || 0).toLocaleString()}

        hr

        .text-center.mt-5
          p Thank you for shopping with us!
          p.text-muted Nyondo General Hardware - Mbale, Uganda

        .text-center.mt-4
          button.btn.btn-primary(onclick='window.print()') 🖨️ Print Receipt
          a.btn.btn-secondary.ms-3(href='/addsale') New Sale