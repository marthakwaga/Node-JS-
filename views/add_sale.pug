extends layout

block content
  .flex-grow-1.p-4(style='max-width: 850px; margin: 0 auto;')
    .card.shadow-lg(style='background: rgba(255, 255, 255, 0.144);')
      .card-header.bg-warning.text-dark.text-center.py-3
        h4.mb-0
          i.fas.fa-cash-register.me-2
          |  New Sale

      .card-body.p-4(style='max-height: 550px; overflow-y: auto;')
        form#saleForm(action='/addsale' method='POST')
          input#itemsInput(type='hidden' name='items')
          input#transportRequestedInput(type='hidden' name='transportRequested')

          .row.mb-4
            .col-md-3
              label.form-label.fw-bold.text-white Sale Date
              input#saleDate.form-control(name='saleDate' type='date' value=new Date().toISOString().split('T')[0])
            .col-md-3
              label.form-label.fw-bold.text-white Sales Representative
              select#representative.form-select(name='representative')
                option(value='') Select Representative
                option(value='Martha') Martha Was
                option(value='John') Carol Was
                option(value='Sarah') Mike Was
            .col-md-3
              label.form-label.fw-bold.text-white Customer Phone
              input#customerPhone.form-control(name='customerPhone' type='tel' placeholder='07xxxxxxxx')
            .col-md-3
              label.form-label.fw-bold.text-white  Customer Name
              input.form-control(
                type='text'
                name='customerName'
                placeholder='Customer name'
              )

          // Product Selection Section
          .border.rounded-3.p-3.mb-4.text-white
            h5.mb-3 Add Product from Stock
            .row.g-3
              .col-md-5
                label.form-label.fw-bold.text-white Product
                select#productSelect.form-select(name='product' onchange='autoFillPrice()')
                  option(value='') Select Product
                  
                  if products && products.length > 0
                    each product in products
                      option(
                        value=product.productName
                        data-price=product.sellingPrice
                        data-quantity=product.quantity
                      ) #{product.productName} - UGX #{product.sellingPrice.toLocaleString()} (Stock: #{product.quantity} #{product.unitOfMeasure})
                  else
                    option(value='') No products available in stock
              .col-md-2
                label.form-label.fw-bold.text-white Quantity
                input#qty.form-control(type='number' value='1' min='1')

              .col-md-2
                label.form-label.fw-bold.text-white Unit Price
                input#unitPrice.form-control(type='number' placeholder='Auto-filled' readonly)

              .col-md-3.d-flex.align-items-end
                button.btn.btn-success.w-100(type='button' onclick='addItem()')
                  i.fas.fa-plus.me-1
                  | Add Item

            // Stock Warning Area
            #stockWarning.alert(style='display: none;')

            // Items Table
            h5.mb-3.mt-4.text-warning Items Added
            .table-responsive(style='max-height: 280px; overflow-y: auto;')
              table#itemsTable.table.table-hover
                thead.table-dark.sticky-top
                  tr
                    th Product
                    th.text-center Qty
                    th.text-end Unit Price
                    th.text-end Total
                    th
                tbody#itemsBody

            // Transport & Total
            .row.mb-4
              .col-md-6
                label.form-label.fw-bold.text-white Distance (KM)
                input#distance.form-control(type='number' min='0' placeholder='Enter distance' oninput='calculateTransport()' name='distance')
              .col-md-4
                label.form-label.fw-bold.text-white Transport Charge
                input#transportCharge.form-control(type='number' readonly value='0' name='transportCharge')
            .d-flex.justify-content-between.align-items-center.p-4.bg-white.rounded-3.mt-4.text-success
              h4.mb-0.fw-bold Grand Total
              h2#grandTotal.mb-0.text-success.fw-bold UGX 0
            .text-center.mt-4
              button.btn.btn-warning.btn-lg.px-5(type='submit') Save & Print Receipt
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  
  script.
    // Global variables
    let products = [];
    let items = [];

    // == TRANSPORT CALCULATION 
    function calculateTransport() {
        const distance = Number(document.getElementById('distance').value) || 0;
        const transportField = document.getElementById('transportCharge');
        const requestedCheckbox = document.getElementById('transportRequested');
        
        const transportRequested = requestedCheckbox ? requestedCheckbox.checked : false;
        const itemsTotal = items.reduce((sum, item) => sum + (item.total || 0), 0);

        let transport = 0;

        // Main Logic
        if (distance <= 10) {
            if (itemsTotal >= 500000) {
                transport = 0;                          // Free for big orders
            } else {
                transport = transportRequested ? 20000 : 0;   // 20k only if requested
            }
        } 
        else if (distance <= 20) {
            transport = 30000;
        } 
        else if (distance <= 30) {
            transport = 50000;
        } 
        else if (distance <= 50) {
            transport = 80000;
        } 
        else {
            transport = 120000;
        }

        // Set transport charge
        transportField.value = transport;

        // Update hidden field for form submission
        const hiddenInput = document.getElementById('transportRequestedInput');
        if (hiddenInput) {
            hiddenInput.value = transportRequested;
        }

        // Update grand total and info
        updateGrandTotal();
        showTransportInfo(distance, itemsTotal, transport, transportRequested);
    }

    // Update Grand Total
    function updateGrandTotal() {
        const itemsTotal = items.reduce((sum, item) => sum + (item.total || 0), 0);
        const transport = Number(document.getElementById('transportCharge').value) || 0;
        
        const grandTotal = itemsTotal + transport;

        const grandEl = document.getElementById('grandTotal');
        if (grandEl) {
            grandEl.innerText = `UGX ${grandTotal.toLocaleString()}`;
        }
    }

    // Show Transport Information
    function showTransportInfo(distance, itemsTotal, transport, requested) {
        const infoEl = document.getElementById('transportInfo');
        if (!infoEl) return;

        if (distance <= 10) {
            if (itemsTotal >= 500000) {
                infoEl.textContent = "🎉 Free Transport (Order ≥ 500,000)";
            } else {
                infoEl.textContent = requested 
                    ? "UGX 20,000 - Customer Requested Transport" 
                    : "No Transport Fee (Customer did not request)";
            }
        } else {
            infoEl.textContent = `Tiered Charge: ${distance} km`;
        }
    }

    // Load Products via API
    async function loadProducts() {
    try {
    const response = await fetch('/products/api');
    if (!response.ok) throw new Error('Failed to fetch products');

    const products = await response.json();
    
    const select = document.getElementById('productSelect');
    select.innerHTML = '<option value="">Select Product</option>';

    products.forEach(product => {
      const option = document.createElement('option');
      option.value = product.productName;
      option.dataset.price = product.sellingPrice;
      option.dataset.quantity = product.quantity;
      option.textContent = `${product.productName} — UGX ${Number(product.sellingPrice).toLocaleString()} (Stock: ${product.quantity} ${product.unitOfMeasure})`;
      select.appendChild(option);
    });

    } catch (error) {
    console.error('Error loading products:', error);
    const select = document.getElementById('productSelect');
    select.innerHTML = '<option value="">Error loading products from database</option>';
    }
    }
    function autoFillPrice() {
    const select = document.getElementById('productSelect');
    const option = select.options[select.selectedIndex];
    
    if (option && option.value) {
      document.getElementById('unitPrice').value = option.dataset.price || '';
    }
    }
    function showStockWarning(productName, stock) {
    const warning = document.getElementById('stockWarning');
    if (stock <= 15) {
      warning.style.display = 'block';
      warning.className = stock <= 5 ? 'alert alert-danger mt-2' : 'alert alert-warning mt-2';
      warning.innerHTML = stock <= 5 
        ? `🚨 CRITICAL: Only ${stock} units left of <strong>${productName}</strong>` 
        : `⚠️ Low Stock: Only ${stock} units left of <strong>${productName}</strong>`;
    } else {
      warning.style.display = 'none';
    }
    }
    function addItem() {
    const select = document.getElementById('productSelect');
    const productName = select.value;
    const qty = parseFloat(document.getElementById('qty').value) || 1;
    const price = parseFloat(document.getElementById('unitPrice').value) || 0;
    const availableStock = parseInt(select.options[select.selectedIndex]?.dataset.quantity) || 0;
    if (!productName) {
    return alert("Please select a product");
    }
    // Low Stock Validation
    if (qty > availableStock) {
    if (!confirm(`⚠️ Only ${availableStock} units available!\\n\nDo you still want to sell ${qty} units?`)) {
    return;
    }
    } else if (availableStock <= 15 && qty > availableStock * 0.7) {
    if (!confirm(`Low stock warning: Only ${availableStock} left.\\nSelling ${qty} units will leave very little stock.\n\nProceed?`)) {
    return;
    }
    }
    items.push({
    product: productName,
    qty,
    price,
    total: qty * price
    });
    renderTable();
    calculateTransport();
    clearInputs();
    document.getElementById('stockWarning').style.display = 'none'; // Clear warning after adding
    }
    function renderTable() {
    const tbody = document.getElementById('itemsBody');
    tbody.innerHTML = '';
    items.forEach((item, index) => {
    tbody.innerHTML += `
    <tr>
    <td>${item.product}</td>
    <td class="text-center">${item.qty}</td>
    <td class="text-end">${Number(item.price).toLocaleString()}</td>
    <td class="text-end fw-bold">${Number(item.total).toLocaleString()}</td>
    <td><button onclick="removeItem(${index})" class="btn btn-sm btn-danger">Remove</button></td>
    </tr>`;
    });
    }
    function removeItem(index) {
    items.splice(index, 1);
    renderTable();
    calculateTransport();
    }
    function clearInputs() {
    document.getElementById('productSelect').value = '';
    document.getElementById('qty').value = 1;
    document.getElementById('unitPrice').value = '';
    }
    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
    loadProducts();
    calculateTransport();
    const saleForm = document.getElementById('saleForm');
    if (saleForm) {
    saleForm.addEventListener('submit', function (e) {
    e.preventDefault();
    if (items.length === 0) return alert("Please add at least one item");
    document.getElementById('itemsInput').value = JSON.stringify(items);
    this.submit();
    });
    }
    });
