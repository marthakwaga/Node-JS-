extends layout

block content
  .flex-grow-1.p-4(style='max-width: 850px; margin: 0 auto;')
    .card.shadow-lg(style='background: rgba(255, 255, 255, 0.144);')
      .card-header.bg-warning.text-dark.text-center.py-3
        h4.mb-0
          i.fas.fa-cash-register.me-2
          |  New Sale
      .card-body.p-4(style='max-height: 500px; overflow-y: auto;')
        form#saleForm(action='/addsale' method='POST')
          input#itemsInput(type='hidden' name='items')
          input#transportRequestedInput(type='hidden' name='transportRequested')
          // Your existing form fields
          .row.mb-4
            .col-md-4
              label.form-label.fw-bold.text-white Sale Date
              input#saleDate.form-control(name='saleDate' type='date' value=new Date().toISOString().split('T')[0])
            .col-md-5
              label.form-label.fw-bold.text-white Sales Representative
              select#representative.form-select(name='representative')
                option(value='') Select Representative
                option(value='Martha') Martha Kwaga
                option(value='John') John Tendo
                option(value='Sarah') Sarah Nakiyemba
                option(value='Robert') Robert Livano
                option(value='Grace') Grace Ishimwe
            .col-md-3
              label.form-label.fw-bold.text-white Customer Phone
              input#customerPhone.form-control(name='customerPhone' type='tel' placeholder='07xxxxxxxx')
          // Add Product Manually
          .border.rounded-3.p-2.mb-4.text-white
            h5.mb-3  Add Product
            .row.g-3
              .col-md-5
                select#productSelect.form-select(name='product' onchange='autoFillPrice()')
                  option(value='') Select Product
                  option(value='Cement 50kg' data-price='25000') Cement
                  option(value='Roofing Sheet' data-code='ROF002' data-price='45000') Roofing Sheet
                  option(value='Binding Wire Roll' data-code='BWR003' data-price='12000') Binding Wire Roll
                  option(value='Emulsion Paint 20L'  data-price='85000') Emulsion Paint 20L
                  option(value='Electrical Wire 1.5mm'  data-price='35000') 1.5mm Electrical Wire
                  option(value='PVC Pipe 4m'  data-price='18000') PVC Pipe 4m
              .col-md-2
                input#qty.form-control(type='number' value='1' min='1' name='qty')
              .col-md-2
                input#unitPrice.form-control(type='number' placeholder='Price' name='unitPrice')
              .col-md-1.d-flex.align-items-end
                button.btn.btn-success.w-100(type='button' onclick='addItem()')
                  i.fas.fa-plus
            // Items Table
            h5.mb-3.text-warning Items Added
              .table-responsive(style='max-height: 320px; overflow-y: auto;')
              table#itemsTable.table.table-hover
                  thead.table-dark.sticky-top
                    tr
                      th Product
                      th.text-center Qty
                      th.text-end Unit Price
                      th.text-end Total
                      th
                  tbody#itemsBody
            .row.mb-4
              .col-md-6
                label.form-label.fw-bold.text-white Distance (KM)
                input#distance.form-control(
                  type='number'
                  min='0'
                  placeholder='Enter distance'
                  oninput='calculateTransport()'
                  name='distance'
                )
              .col-md-4
                label.form-label.fw-bold.text-white Transport Charge
                input#transportCharge.form-control(
                  type='number'
                  readonly
                  value='0'
                  name='transportCharge'
                )
            .d-flex.justify-content-between.align-items-center.p-4.bg-white.rounded-3.mt-4.text-success
              h4.mb-0.fw-bold Grand Total
              h2#grandTotal.mb-0.text-success.fw-bold UGX 0
            .text-center.mt-4
              button.btn.btn-warning.btn-lg.px-5(type='submit') Save &amp; Print Receipt
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script(src='js/app.js')
  script.
            let items = [];
    
    function autoFillPrice() {
        const select = document.getElementById('productSelect');
        const option = select.options[select.selectedIndex];
        if (option && option.value) {
            document.getElementById('unitPrice').value = option.dataset.price || '';
        }
    }

    function addItem() {
        const product = document.getElementById('productSelect').value;
        const qty = parseFloat(document.getElementById('qty').value) || 1;
        const price = parseFloat(document.getElementById('unitPrice').value) || 0;

        if (!product) return alert("Please select a product");

        items.push({ 
            product, 
            qty, 
            price, 
            total: qty * price 
        });

        renderTable();
        calculateTransport();
        clearInputs();
    }

    function renderTable() {
        const tbody = document.getElementById('itemsBody');
        tbody.innerHTML = '';
        items.forEach((item, index) => {
            tbody.innerHTML += `
            <tr>
                <td>${item.product}</td>
                <td class="text-center">${item.qty}</td>
                <td class="text-end">${item.price.toLocaleString()}</td>
                <td class="text-end fw-bold">${item.total.toLocaleString()}</td>
                <td><button onclick="removeItem(${index})" class="btn btn-sm btn-danger">Remove</button></td>
            </tr>`;
        });
    }

    function removeItem(index) {
        items.splice(index, 1);
        renderTable();
        calculateTransport();
    }

    // ===================== MAIN FUNCTION =====================
    function calculateTransport() {
        const distanceEl = document.getElementById('distance');
        const transportField = document.getElementById('transportCharge');
        const requestedEl = document.getElementById('transportRequested');

        if (!distanceEl || !transportField) return;

        const distance = Number(distanceEl.value) || 0;
        const transportRequested = requestedEl ? requestedEl.checked : false;
        const itemsTotal = items.reduce((sum, item) => sum + (item.total || 0), 0);

        let transport = 0;

        if (distance <= 10) {
            if (itemsTotal >= 500000) {
                transport = 0;
            } else {
                transport = transportRequested ? 20000 : 0;
            }
        } 
        else if (distance <= 20) transport = 30000;
        else if (distance <= 30) transport = 50000;
        else if (distance <= 50) transport = 80000;
        else transport = 120000;

        transportField.value = transport;

        // Update hidden field
        const hiddenRequested = document.getElementById('transportRequestedInput');
        if (hiddenRequested) hiddenRequested.value = transportRequested;

        updateGrandTotal();
        showTransportInfo(distance, itemsTotal, transport, transportRequested);
    }

    function updateGrandTotal() {
        const itemsTotal = items.reduce((sum, item) => sum + (item.total || 0), 0);
        const transport = Number(document.getElementById('transportCharge').value) || 0;
        
        const grandTotal = itemsTotal + transport;

        const grandEl = document.getElementById('grandTotal');
        if (grandEl) {
            grandEl.innerText = `UGX ${grandTotal.toLocaleString()}`;
        }
    }

    function showTransportInfo(distance, itemsTotal, transport, requested) {
        const infoEl = document.getElementById('transportInfo');
        if (!infoEl) return;

        if (distance <= 10) {
            if (itemsTotal >= 500000) {
                infoEl.textContent = "🎉 Free Transport (Order ≥ 500,000)";
            } else {
                infoEl.textContent = requested 
                    ? "UGX 20,000 Transport (Customer Requested)" 
                    : "No Transport Fee";
            }
        } else {
            infoEl.textContent = `Distance Tier: ${distance} km`;
        }
    }

    function clearInputs() {
        document.getElementById('productSelect').value = '';
        document.getElementById('qty').value = 1;
        document.getElementById('unitPrice').value = '';
    }

    // Submit Handler
    document.addEventListener('DOMContentLoaded', () => {
        // Initial calculation
        calculateTransport();

        const saleForm = document.getElementById('saleForm');
        if (saleForm) {
            saleForm.addEventListener('submit', function (e) {
                e.preventDefault();

                if (items.length === 0) {
                    return alert("Please add at least one item");
                }

                document.getElementById('itemsInput').value = JSON.stringify(items);
                this.submit();
            });
        }
    });