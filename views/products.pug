extends layout

block content
  .flex-grow-1.p-4(style='max-width: 1000px; margin: 0 auto; height: 100vh; overflow-y: auto;')
    .d-flex.justify-content-between.align-items-center.mb-4
      h2.text-white
        i.fas.fa-boxes.me-2
        | Products & Stock

      a.btn.btn-warning.btn-lg(href='/add_stock')
        | Add New Product
        
    .row.mb-4
      .col-md-6
        input#searchInput.form-control.form-control-lg(placeholder='Search by product name...' onkeyup='filterProducts()' style='color:white; background:rgba(255,255,255,0.1);')
      .col-md-3
        select#categoryFilter.form-select.form-select-lg(onchange='filterProducts()')
          option(value='') All Categories
          option(value='Building Materials') Building Materials
          option(value='Steel') Steel Products
          option(value='Tools') Tools & Equipment
          option(value='Cement') Cement & Concrete
      .col-md-3
        select#stockFilter.form-select.form-select-lg(onchange='filterProducts()')
          option(value='') All Stock Levels
          option(value='low') Low Stock (≤ 15)
          option(value='out') Out of Stock

    // Products Table
    .card
      .card-body
        .table-responsive
          table.table.table-hover.align-middle
            thead.table-dark
              tr
                th Image
                th Product
                th Type
                th Cost Price
                th Selling Price
                th Stock
                th Supplier
                th Status
                th Actions
            tbody#productsBody
              each product in products
                tr
                  td
                    img(
                      src=`/${product.itemImage.replace(/\\/g, '/')}`
                      alt='Product Image'
                      style='width:70px; height:70px; object-fit:cover; border-radius:8px;'
                    )
                  td #{product.productName}
                  td UGX #{Number(product.costPrice || 0).toLocaleString()}
                  td UGX #{Number(product.sellingPrice || 0).toLocaleString()}
                  td #{product.quantity} #{product.unitOfMeasure}

                  td #{product.supplierName}

                  td
                    if product.quantity > 15
                      span.badge.bg-success In Stock

                    else if product.quantity > 0
                      span.badge.bg-warning.text-dark Low Stock

                    else
                      span.badge.bg-danger Out of Stock

  // ===== EDIT PRODUCT MODAL 
  #editProductModal.modal.fade(tabindex='-1')
    .modal-dialog.modal-lg
      .modal-content
        .modal-header.bg-warning.text-dark
          h5.modal-title Edit Product
          button.btn-close(type='button' data-bs-dismiss='modal')

        .modal-body
          input#editProductId(type='hidden')

          .row.g-3
            .col-12.mb-3
              label.form-label Product Name
              input#editProductName.form-control(type='text' required)

            .col-md-6.mb-3
              label.form-label Category
              input#editCategory.form-control(type='text')

            .col-md-6.mb-3
              label.form-label Supplier
              input#editSupplier.form-control(type='text')

            .col-md-4.mb-3
              label.form-label Cost Price (UGX)
              input#editCostPrice.form-control(type='number' required)

            .col-md-4.mb-3
              label.form-label Selling Price (UGX)
              input#editSellingPrice.form-control(type='number' required)

            .col-md-4.mb-3
              label.form-label Stock Quantity
              input#editQuantity.form-control(type='number' required)

        .modal-footer
          button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
          button.btn.btn-success(type='button' onclick='updateProduct()')
            i.fas.fa-save.me-2
            | Save Changes

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')

  script.
    let productsData = [];

    async function loadProducts() {
      try {
        console.log("🚀 Starting fetch to /products/api...");
        const res = await fetch('/products/api');
        
        console.log("📡 Response status:", res.status);
        
        const data = await res.json();
        console.log("📦 Raw data received:", data);
        console.table(data);   // This will show the structure clearly

        productsData = data;

        if (!Array.isArray(data) || data.length === 0) {
          document.getElementById('productsBody').innerHTML = `
            <tr><td colspan="9" class="text-center py-5 text-warning">
              No products found in database.<br>
              <small>Add some products first.</small>
            </td></tr>`;
          return;
        }

        renderProducts(data);

      } catch (err) {
        console.error("❌ Fetch error:", err);
        document.getElementById('productsBody').innerHTML = `<tr><td colspan="9" class="text-danger text-center py-5">Error loading data</td></tr>`;
      }
    }

    function renderProducts(data) {
      const tbody = document.getElementById('productsBody');
      tbody.innerHTML = '';

      data.forEach((p, index) => {
        console.log(`Product ${index}:`, p); // Debug each product

        const stock = parseInt(p.quantity || p.stockQuantity || 0);

        let imagePath = p.itemImage ? 
          '/' + String(p.itemImage).replace(/\\/g, '/').replace(/^public\//i, '') : 
          '/images/no-image.png';

        const row = `
          <tr>
            <td><img src="${imagePath}" style="width:70px;height:70px;object-fit:cover;border-radius:8px;" onerror="this.src='/images/no-image.png'"></td>
            <td><strong>${p.productName || p.name || '-'}</strong></td>
            <td>${p.productType || p.category || '-'}</td>
            <td>UGX ${Number(p.costPrice || p.buyingPrice || 0).toLocaleString()}</td>
            <td class="fw-bold text-success">UGX ${Number(p.sellingPrice || 0).toLocaleString()}</td>
            <td class="fw-bold">${stock} ${p.unitOfMeasure || ''}</td>
            <td>${p.supplierName || '-'}</td>
            <td>
              <span class="badge ${stock === 0 ? 'bg-danger' : stock <= 15 ? 'bg-warning text-dark' : 'bg-success'}">
                ${stock === 0 ? 'Out of Stock' : stock <= 15 ? 'Low Stock' : 'In Stock'}
              </span>
            </td>
            <td>
              <button onclick="editProduct('${p._id}')" class="btn btn-sm btn-warning">Edit</button>
              <button onclick="deleteProduct('${p._id}')" class="btn btn-sm btn-danger ms-1">Delete</button>
            </td>
          </tr>`;
        tbody.innerHTML += row;
      });
    }

    // Edit Product
    async function editProduct(id) {
      console.log("🔧 Editing product ID:", id);

      try {
        const res = await fetch(`/products/${id}`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const product = await res.json();
        console.log("✅ Product data:", product);

        // Fill form fields
        document.getElementById('editProductId').value = product._id || id;
        document.getElementById('editProductName').value = product.productName || product.name || '';
        document.getElementById('editCategory').value = product.productType || product.category || '';
        document.getElementById('editSupplier').value = product.supplierName || '';
        document.getElementById('editCostPrice').value = product.costPrice || product.buyingPrice || '';
        document.getElementById('editSellingPrice').value = product.sellingPrice || '';
        document.getElementById('editQuantity').value = product.quantity || product.stockQuantity || '';

        new bootstrap.Modal(document.getElementById('editProductModal')).show();

      } catch (err) {
        console.error("Edit Error:", err);
        alert("Failed to load product. Check console (F12)");
      }
    }

    async function updateProduct() {
      const id = document.getElementById('editProductId').value;
      if (!id) return alert("Product ID is missing");

      const data = {
        productName: document.getElementById('editProductName').value,
        productType: document.getElementById('editCategory').value,
        supplierName: document.getElementById('editSupplier').value,
        costPrice: Number(document.getElementById('editCostPrice').value),
        sellingPrice: Number(document.getElementById('editSellingPrice').value),
        quantity: Number(document.getElementById('editQuantity').value)
      };

      try {
        const res = await fetch(`/products/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (res.ok) {
          bootstrap.Modal.getInstance(document.getElementById('editProductModal')).hide();
          loadProducts();
          alert("✅ Product updated successfully!");
        } else {
          alert("Failed to update product");
        }
      } catch (err) {
        console.error(err);
        alert("Error saving changes");
      }
    }

    function deleteProduct(id) {
      if (confirm("Delete this product permanently?")) {
        fetch(`/products/${id}`, { method: 'DELETE' })
          .then(() => loadProducts());
      }
    }

    function filterProducts() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const category = document.getElementById('categoryFilter').value;
      const stockLevel = document.getElementById('stockFilter').value;

      const filtered = productsData.filter(p => {
        const matchesSearch = (p.productName || '').toLowerCase().includes(search);
        const matchesCategory = !category || (p.productType || p.category) === category;
        const stock = parseInt(p.quantity) || 0;
        let matchesStock = true;
        if (stockLevel === 'low') matchesStock = stock > 0 && stock <= 15;
        if (stockLevel === 'out') matchesStock = stock === 0;
        return matchesSearch && matchesCategory && matchesStock;
      });

      renderProducts(filtered);
    }
    window.onload = loadProducts;