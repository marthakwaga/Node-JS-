extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .container-fluid

      .d-flex.justify-content-between.align-items-center.mb-4
        h2.text-white.fw-bold Expenses

      .row

        // Add Expense Form
        .col-lg-4.mb-4
          .card
            .card-header.bg-warning.text-dark
              h5.mb-0.fw-bold Add Expense
            .card-body
              form(action='/expenses' method='POST')

                .mb-3
                  label.form-label Description
                  input.form-control(
                    name='description'
                    type='text'
                    placeholder='e.g. Monthly Rent'
                    required
                  )

                .mb-3
                  label.form-label Amount (UGX)
                  input.form-control(
                    name='amount'
                    type='number'
                    placeholder='50,000'
                    min='0'
                    step='1000'
                    required
                  )

                .mb-3
                  label.form-label Category
                  select.form-select(name='category')
                    option(value='Rent') Rent
                    option(value='Salary') Salary
                    option(value='Utilities') Utilities
                    option(value='Supplies') Supplies
                    option(value='Transport') Transport
                    option(value='Other') Other

                .mb-3
                  label.form-label Date
                  input.form-control(
                    name='date'
                    type='date'
                  )

                button.btn.btn-dark.w-100(type='submit') Add Expense

        // Expenses Table
        .col-lg-8.mb-4
          .card
            .card-header.bg-warning.text-dark.d-flex.justify-content-between.align-items-center
              h5.mb-0.fw-bold All Expenses
              span.fw-bold Total: UGX #{total ? total.toLocaleString() : '0'}

            .card-body.p-0
              .table-responsive
                table.table.table-hover.mb-0
                  thead.table-light
                    tr
                      th Date
                      th Description
                      th Category
                      th.text-end Amount (UGX)
                      th Action

                  tbody
                    if expenses.length > 0
                      each expense in expenses
                        tr
                          td= new Date(expense.date).toLocaleDateString()
                          td= expense.description
                          td
                            - var catClass = {'Rent': 'bg-primary', 'Salary': 'bg-success', 'Utilities': 'bg-info', 'Supplies': 'bg-warning', 'Transport': 'bg-secondary', 'Other': 'bg-dark'}[expense.category] || 'bg-dark'
                            span.badge(class=catClass)= expense.category
                          td.text-end.text-danger.fw-bold= expense.amount.toLocaleString()
                          td
                            form(action=`/expenses/delete/${expense._id}` method='POST')
                              button.btn.btn-sm.btn-outline-danger(type='submit') Delete
                    else
                      tr
                        td(colspan='5').text-center.text-muted No expenses recorded yet

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')