extends layout 

block content 
  .flex-grow-1.p-4.overflow-auto
    .container-fluid
      h2.mb-4.text-white Admin Dashboard
      // KPI Cards
      .row.g-4.mb-5
        .col-xl-3.col-md-6
          .card.h-100.border-0.shadow
            .card-body
              h5.text-muted.fw-bold Total Sales Revenue
              h3.text-success.fw-bold #{stats.salesRevenue.toLocaleString()}/=
        .col-xl-3.col-md-6
          .card.h-100.border-0.shadow
            .card-body
              h5.text-muted.fw-bold Total Stock Value
              h3.fw-bold #{stats.inventoryValue.toLocaleString()}/=
        .col-xl-3.col-md-6
          .card.h-100.border-0.shadow
            .card-body
              h5.text-muted.fw-bold Active Deposits
              h3.fw-bold #{Number(stats.activeDepositAmount || 0).toLocaleString()}/=
              small #{stats.activeMembers} Members
        .col-xl-3.col-md-6
          .card.h-100.border-0.shadow
            .card-body
              h5.text-muted.fw-bold Pending Credit
              h3.text-warning.fw-bold #{Number(stats.pendingCreditAmount || 0).toLocaleString()}
              small #{stats.pendingCreditSuppliers} Suppliers
      // Recent Sales & Low Stock
      .row
        .col-lg-7
          .card.shadow
            .card-header.bg-white
              h5.fw-bold Recent Sales
            .card-body
              table.table.table-hover
                thead
                  tr
                    th Date
                    th Customer
                    th Amount
                    th Items
                tbody
                  if recentSales.length > 0
                    each sale in recentSales
                      tr
                        td= sale.createdAt.toDateString()
                        td=sale.customerName
                        td.text-success= sale.totalAmount.toLocaleString()
                        td= sale.items.length 
                  else 
                    tr 
                      td(colspan='4') No sales found
        .col-lg-5
          .card.shadow
            .card-header.bg-warning.text-dark
              h5.fw-bold Low Stock Alert
            .card-body
              ul.list-group
                each item in lowStockItems
                  li.list-group-item.d-flex.justify-content-between
                    | #{item.ProductName} 
                    span.badge.bg-danger #{item.quantity} left
  script(src='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.js')
