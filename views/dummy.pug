          extends layout 

block content
  .flex-grow-1.p-4.overflow-auto
    .container-fluid
      h2.text-white.mb-4 Record New Expense
      .row.justify-content-center
        .col-lg-8
          .card
            .card-header.bg-warning.text-dark
              h5
                i.fas.fa-file-invoice-dollar
                |  New Expense Entry
            .card-body
              form
                .row
                  .col-md-6.mb-3
                    label.form-label Expense Date
                    input.form-control(name='date' type='date' value='2026-05-02' required='')
                  .col-md-6.mb-3
                    label.form-label Amount (UGX)
                    input.form-control.form-control-lg(name='amount' type='number' placeholder='150,000' required='')
                .mb-3
                  label.form-label Expense Category
                  select.form-select.form-select-lg(required='')
                    option(value='') Select Category
                    option(value='salaries') Salaries &amp; Wages
                    option(value='rent') Rent &amp; Utilities
                    option(value='transport') Transportation &amp; Fuel
                    option(value='marketing') Marketing &amp; Advertising
                    option(value='maintenance') Maintenance &amp; Repairs
                    option(value='supplies') Office Supplies
                    option(value='other') Other Expenses
                .mb-3
                  label.form-label Description / Paid To
                  input.form-control(type='text' placeholder='e.g. Staff salaries for April' required='')
                .mb-3
                  label.form-label Payment Method
                  .btn-group.w-100(role='group')
                    input#cash.btn-check(type='radio' name='payment' checked='')
                    label.btn.btn-outline-secondary(for='cash') Cash
                    input#bank.btn-check(type='radio' name='payment')
                    label.btn.btn-outline-secondary(for='bank') Bank Transfer
                    input#mobile.btn-check(type='radio' name='payment')
                    label.btn.btn-outline-secondary(for='mobile') Mobile Money
                .mb-3
                  label.form-label Notes (Optional)
                  textarea.form-control(rows='3' placeholder='Additional details...')
                button.btn.btn-warning.w-100(type='submit')
                  i.fas.fa-save
                  |  Save Expense
          // Recent Expenses
          .card.mt-4
            .card-header
              h5 Recent Expenses
            .card-body.p-0
              table.table.table-hover.mb-0
                thead.table-light
                  tr
                    th Date
                    th Category
                    th Description
                    th.text-end Amount
                tbody
                  tr
                    td 2026-05-02
                    td Salaries
                    td Staff Salaries - April
                    td.text-end.fw-bold 3,850,000
                  tr
                    td 2026-05-01
                    td Rent
                    td Shop Rent - May
                    td.text-end.fw-bold 2,100,000
                  tr
                    td 2026-04-30
                    td Fuel
                    td Fuel for delivery truck
                    td.text-end.fw-bold 450,000
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
