extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .container-fluid

      .d-flex.justify-content-between.align-items-center.mb-4.text-warning
        h2 Welcome back, #{user.username}!
        .text-end
          #currentDate.fw-bold.text-white

      // Quick Stats
      .row.g-4.mb-5
        .col-xl-3.col-md-6
          .card.border-0.shadow.h-100
            .card-body
              h5.text-muted.fw-bold Today's Sales
              h3.text-success.fw-bold UGX #{todayRevenue ? todayRevenue.toLocaleString() : '0'}
              small.text-success= transactionCount + ' Transactions'

        .col-xl-3.col-md-6
          .card.border-0.shadow.h-100
            .card-body
              h5.text-muted.fw-bold Items Sold
              h3.fw-bold= itemsSold || '0'

        .col-xl-3.col-md-6
          .card.border-0.shadow.h-100
            .card-body
              h5.text-muted.fw-bold Average Sale
              h3.fw-bold UGX #{averageSale ? averageSale.toLocaleString() : '0'}

        .col-xl-3.col-md-6
          .card.border-0.shadow.h-100
            .card-body
              h5.text-muted.fw-bold Cash Collected
              h3.text-primary.fw-bold UGX #{cashCollected ? cashCollected.toLocaleString() : '0'}

      // Quick Actions
      .row.mb-5
        .col-md-6.col-lg-3.mb-3
          a.btn.btn-success.btn-lg.w-100.py-4.shadow(href='/addsale')
            i.fas.fa-plus.fa-2x.mb-2.d-block
            h5.mb-0.fw-bold New Sale

        .col-md-6.col-lg-3.mb-3
          a.btn.btn-warning.btn-lg.w-100.py-4.shadow(href='/products')
            i.fas.fa-boxes.fa-2x.mb-2.d-block
            h5.mb-0.fw-bold Products
      // Recent Sales
      .card.shadow
        .card-header.bg-white
          h5.fw-bold Recent Sales (Today)
        .card-body.p-0
          .table-responsive
            table.table.table-hover.mb-0
              thead.table-light
                tr
                  th Time
                  th Customer
                  th Items
                  th.text-end Amount
                  th.text-center Payment

              tbody
                if recentSales.length > 0
                  each sale in recentSales
                    tr
                      td= new Date(sale.createdAt).toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'})
                      td= sale.customerName
                      td= sale.items.length
                      td.text-end.fw-bold= 'UGX ' + sale.totalAmount.toLocaleString()
                      td.text-center
                        - var badgeClass = sale.paymentStatus === 'paid' ? 'bg-success' : sale.paymentStatus === 'pending' ? 'bg-warning' : 'bg-info'
                        span.badge(class=badgeClass)= sale.paymentStatus
                else
                  tr
                    td(colspan='5').text-center.text-muted No sales recorded today

  script.
    // Display current date
    const dateEl = document.getElementById('currentDate');
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('en-UG', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
      });
    }