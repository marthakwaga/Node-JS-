doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title SUPPLIER CREDIT
  // MDB
  link(href='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css' rel='stylesheet')
  // Bootstrap
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/mdb.min.css')
  link(rel='stylesheet' href='/css/nyondo.css')
// Background Image
#intro-example.bg-image.min-vh-100.d-flex(style="background-image: url('https://images.pexels.com/photos/4312849/pexels-photo-4312849.jpeg');")
  // Dark Overlay
  .mask.mask-custom.flex-grow-1(style='background-color: rgba(25, 12, 36, 0.75);')
    .d-flex.h-100
      // Sidebar
      nav.sidebar.p-3.text-white(style='width: 260px; background: rgba(242, 240, 242, 0.336);')
        .logo.mx-auto.mb-4(style="background-image: url('/images/logo.png'); \
        width: 150px; height: 150px; \
        background-size: contain; \
        background-repeat: no-repeat;")
        ul.nav.flex-column
          li.nav-item
            a.nav-link.text-white(href='dashboard.html')
              i.fas.fa-tachometer-alt
              span(data-translate='dashboard') Dashboard
          li.nav-item
            a.nav-link.text-white(href='products.html')
              i.fas.fa-boxes
              span(data-translate='products') Products &amp; Stock
          li.nav-item
            a.nav-link.text-white.active(href='stock-in.html')
              i.fas.fa-truck-loading
              span(data-translate='stockIn') Stock In
          li.nav-item
            a.nav-link.text-white(href='sales.html')
              i.fas.fa-shopping-cart
              span(data-translate='sales') Sales
          li.nav-item
            a.nav-link.text-white(href='deposits.html')
              i.fas.fa-hand-holding-usd
              span(data-translate='deposits') Deposit Scheme
          li.nav-item
            a.nav-link.text-white(href='suppliers.html')
              i.fas.fa-users
              span(data-translate='suppliers') Suppliers
          li.nav-item
            a.nav-link.text-white(href='reports.html')
              i.fas.fa-chart-bar
              span(data-translate='reports') Reports
          li.nav-item
            a.nav-link.text-white(href='offline.html')
              i.fas.fa-wifi
              span(data-translate='offline') Offline Mode
        button.btn.btn-outline-warning.w-100.mt-4(onclick='logout()' data-translate='logout') Logout
      // Main Content - Centered
      form.col.overflow-y-auto(action='/supplier' method='post')
      .flex-grow-1.d-flex.align-items-center.justify-content-center.p-4.overflow-auto
        .w-100(style='max-width: 900px;')
          h2.text-white.mb-4(data-translate='suppliers') Supplier Credit Management
          .card
            .card-body
              h5 Current Supplier Credit
              table.table.table-hover
                thead.table-dark
                  tr
                    th Supplier Name
                    th Amount Owed (UGX)
                    th Due Date
                    th Status
                    th Action
                tbody
                  tr
                    td Factory Depot Uganda Ltd
                    td.text-danger.fw-bold 12,450,000
                    td 2026-05-15
                    td
                      span.badge.bg-warning Pending
                    td
                      button.btn.btn-sm.btn-outline-primary Record Payment
                  tr
                    td Steel Masters Ltd
                    td.text-success 0
                    td -
                    td
                      span.badge.bg-success Cleared
                    td
          .text-center.mt-4
            button.btn.btn-warning.btn-lg(data-bs-toggle='modal' data-bs-target='#addSupplierModal')
              | + Add New Credit
// Add Supplier Modal
#addSupplierModal.modal.fade(tabindex='-1')
  .modal-dialog
    .modal-content
      .modal-header
        h5.modal-title Add New Credit
        button.btn-close(type='button' data-bs-dismiss='modal')
      .modal-body
        label.form-label Supplier Name
        input.form-control.mb-3(name='supplierName' type='text' placeholder='Supplier Name')
        label.form-label Credit Amount
        input.form-control(name='creditAmount' type='number' placeholder='Credit Amount')
        br
        label.form-label Due Date
        input.form-control.mb-3(name='dueDate' type='date' placeholder='Due Date')
        label.form-label Items Supplied
        input.form-control.mb-3(name='itemsSupplied' type='text' placeholder='Items Supplied')
      .modal-footer
        button.btn.btn-dark(data-bs-dismiss='modal') Cancel
        button.btn.btn-warning(type='submit') Save Supplier
// Scripts
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
script(src='js/app.js')
script(src='js/translations.js')
