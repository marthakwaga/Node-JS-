extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .w-100(style='max-width: 1150px;')
      h2.text-white.mb-4.fw-bold Supplier Credit Management
      // Summary Cards
      .row.mb-4
        .col-md-4
          .card.text-white(style='background: rgba(255,193,7,0.9);')
            .card-body
              h5 Total Owed
              h3= totalOwed ? totalOwed.toLocaleString() + ' UGX' : '0 UGX'
        .col-md-4
          .card.bg-success.text-white
            .card-body
              h5 Total Paid
              h3= totalPaid ? totalPaid.toLocaleString() + ' UGX' : '0 UGX'
        .col-md-4
          .card.bg-danger.text-white
            .card-body
              h5 Overdue Credits
              h3= overdueCount || '0'

      // Main Credit Table
      .card
        .card-body
          h5.mb-3.fw-bold Current Supplier Credits
          .table-responsive
            table.table.table-hover.align-middle
              thead.table-dark
                tr
                  th Supplier Name
                  th Amount Owed (UGX)
                  th Amount Paid (UGX)
                  th Balance (UGX)
                  th Due Date
                  th Status
                  th Items Supplied
                  th Actions
              tbody
                if credits.length > 0
                  each credit in credits
                    tr
                      td.fw-bold= credit.supplierName
                      td= credit.creditAmount.toLocaleString()
                      td.text-success= credit.amountPaid.toLocaleString()
                      td
                        - const balClass = credit.balance <= 0 ? 'text-success fw-bold' : credit.status === 'Overdue' ? 'text-danger fw-bold' : 'text-warning fw-bold'
                        span(class=balClass)= credit.balance.toLocaleString()
                      td= new Date(credit.dueDate).toLocaleDateString()
                      td
                        - const statusClass = credit.status === 'Cleared' ? 'bg-success' : credit.status === 'Overdue' ? 'bg-danger' : credit.status === 'Partially Paid' ? 'bg-info' : 'bg-warning text-dark'
                        span.badge(class=statusClass)= credit.status
                      td
                        button.btn.btn-sm.btn-outline-secondary(
                          data-bs-toggle='modal'
                          data-bs-target='#itemsModal-' + credit._id
                        )
                          i.fas.fa-list.me-1
                          | #{credit.itemsSupplied.length} item(s)
                      td
                        .d-flex.gap-1
                          button.btn.btn-sm.btn-warning(
                            data-bs-toggle='modal'
                            data-bs-target='#paymentModal-' + credit._id
                          ) Pay
                          button.btn.btn-sm.btn-outline-danger(
                            onclick=`deleteCredit('${credit._id}')`
                          ) Delete
                else
                  tr
                    td(colspan='8').text-center.text-muted No credits recorded yet

      // Payment History Section
      .card.mt-4
        .card-header.bg-dark.text-white
          h5.mb-0.fw-bold Payment History
        .card-body
          .table-responsive
            table.table.table-hover
              thead.table-light
                tr
                  th Supplier
                  th Credit Amount
                  th Paid
                  th Balance
                  th Status
              tbody
                if credits.length > 0
                  each credit in credits
                    tr
                      td= credit.supplierName
                      td= credit.creditAmount.toLocaleString() + ' UGX'
                      td.text-success= credit.amountPaid.toLocaleString() + ' UGX'
                      td
                        - const histBalClass = credit.balance <= 0 ? 'text-success' : 'text-danger'
                        span(class=histBalClass)= credit.balance.toLocaleString() + ' UGX'
                      td
                        - const histStatusClass = credit.status === 'Cleared' ? 'bg-success' : credit.status === 'Overdue' ? 'bg-danger' : credit.status === 'Partially Paid' ? 'bg-info' : 'bg-warning text-dark'
                        span.badge(class=histStatusClass)= credit.status
                else
                  tr
                    td(colspan='5').text-center.text-muted No payment history yet

      // Add New Credit Button
      .text-center.mt-4
        button.btn.btn-warning.btn-lg(data-bs-toggle='modal' data-bs-target='#addSupplierModal')
          i.fas.fa-plus.me-2
          | Add New Credit

  // Add New Credit Modal
  #addSupplierModal.modal.fade(tabindex='-1')
    .modal-dialog.modal-lg
      .modal-content
        .modal-header.bg-warning.text-dark
          h5.modal-title Add New Supplier Credit
          button.btn-close(type='button' data-bs-dismiss='modal')
        form#creditForm(action='/supplier' method='post')
          .modal-body
            .row
              .col-md-6.mb-3
                label.form-label Supplier Name
                input.form-control(name='supplierName' type='text' required)
              .col-md-6.mb-3
                label.form-label Due Date
                input.form-control(name='dueDate' type='date' required)
            .mb-4
              label.form-label Items Supplied
              table#itemsTable.table.table-bordered.table-sm
                thead.table-light
                  tr
                    th Item Description
                    th Qty
                    th Unit Price
                    th Amount
                    th
                tbody
              .row.g-2.mb-3
                .col-5
                  input#itemDesc.form-control.form-control-sm(placeholder='Item description')
                .col-2
                  input#itemQty.form-control.form-control-sm(type='number' value='1' min='1')
                .col-3
                  input#itemPrice.form-control.form-control-sm(type='number' placeholder='Unit price')
                .col-2
                  button.btn.btn-success.btn-sm#btnAddItem(type='button') Add Item
              .d-flex.justify-content-between.align-items-center.bg-light.p-3.rounded
                h5.mb-0 Total Credit Amount:
                h4.mb-0.text-warning#totalDisplay 0 UGX
            input#creditAmount(name='creditAmount' type='hidden')
            input#itemsData(name='itemsSupplied' type='hidden')
          .modal-footer
            button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
            button.btn.btn-warning(type='submit') Save Supplier Credit

  // Payment Modals — one per credit
  if credits.length > 0
    each credit in credits
      - const paymentModalId = 'paymentModal-' + credit._id
      .modal.fade(id=paymentModalId tabindex='-1' aria-hidden='true')
        .modal-dialog
          .modal-content
            .modal-header.bg-warning.text-dark
              h5.modal-title Record Payment — #{credit.supplierName}
              button.btn-close(type='button' data-bs-dismiss='modal')
            form(action=`/supplier/${credit._id}/payment` method='POST')
              .modal-body
                p.mb-1
                  strong Supplier:
                  |  #{credit.supplierName}
                p.mb-1
                  strong Total Credit:
                  |  UGX #{credit.creditAmount.toLocaleString()}
                p.mb-3
                  strong Balance Remaining:
                  span.text-danger.fw-bold  UGX #{credit.balance.toLocaleString()}
                hr
                .mb-3
                  label.form-label Payment Amount (UGX)
                  input.form-control(
                    type='number'
                    name='paymentAmount'
                    min='1'
                    max=credit.balance
                    required
                  )
                .mb-3
                  label.form-label Notes
                  textarea.form-control(name='notes' rows='2')
              .modal-footer
                button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
                button.btn.btn-success(type='submit') Record Payment

    // Items Modals — one per credit
    each credit in credits
      - const itemsModalId = 'itemsModal-' + credit._id
      .modal.fade(id=itemsModalId tabindex='-1' aria-hidden='true')
        .modal-dialog.modal-lg
          .modal-content
            .modal-header.bg-dark.text-white
              h5.modal-title Items Supplied — #{credit.supplierName}
              button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal')
            .modal-body
              if credit.itemsSupplied && credit.itemsSupplied.length > 0
                table.table.table-bordered
                  thead.table-dark
                    tr
                      th #
                      th Description
                      th Qty
                      th Unit Price
                      th.text-end Amount
                  tbody
                    each item, index in credit.itemsSupplied
                      tr
                        td= index + 1
                        td= item.description
                        td= item.quantity
                        td= item.unitPrice.toLocaleString() + ' UGX'
                        td.text-end.fw-bold= item.amount.toLocaleString() + ' UGX'
                  tfoot.table-light
                    tr
                      td(colspan='4').text-end.fw-bold Total
                      td.text-end.fw-bold.text-warning= credit.creditAmount.toLocaleString() + ' UGX'
              else
                p.text-muted.text-center No items recorded for this credit
            .modal-footer
              button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Close

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    let items = [];

    document.getElementById("btnAddItem").addEventListener("click", addItem);

    function addItem() {
      const desc = document.getElementById("itemDesc").value.trim();
      const qty = parseFloat(document.getElementById("itemQty").value) || 0;
      const price = parseFloat(document.getElementById("itemPrice").value) || 0;

      if (!desc || price <= 0) {
        alert("Please enter a valid item description and unit price");
        return;
      }

      const amount = qty * price;
      items.push({ description: desc, quantity: qty, unitPrice: price, amount: amount });
      renderTable();
      clearInputs();
    }

    function renderTable() {
      const tbody = document.querySelector("#itemsTable tbody");
      tbody.innerHTML = "";
      let total = 0;

      items.forEach(function(item, index) {
        total += item.amount;
        const row = `
          <tr>
            <td>${item.description}</td>
            <td>${item.quantity}</td>
            <td>${item.unitPrice.toLocaleString()}</td>
            <td>${item.amount.toLocaleString()}</td>
            <td><button type="button" class="btn btn-danger btn-sm" onclick="removeItem(${index})">×</button></td>
          </tr>`;
        tbody.innerHTML += row;
      });

      document.getElementById("totalDisplay").textContent = total.toLocaleString() + " UGX";
      document.getElementById("creditAmount").value = total;
      document.getElementById("itemsData").value = JSON.stringify(items);
    }

    function removeItem(index) {
      items.splice(index, 1);
      renderTable();
    }

    function clearInputs() {
      document.getElementById("itemDesc").value = "";
      document.getElementById("itemQty").value = "1";
      document.getElementById("itemPrice").value = "";
    }

    function deleteCredit(id) {
      if (confirm("Delete this credit permanently?")) {
        fetch("/supplier/" + id, { method: "DELETE" })
          .then(function() { location.reload(); });
      }
    }

    document.getElementById("itemPrice").addEventListener("keypress", function(e) {
      if (e.key === "Enter") addItem();
    });