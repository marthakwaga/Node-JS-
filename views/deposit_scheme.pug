extends layout 

block content
  .flex-grow-1.p-6.overflow-auto(style='max-width: 1000px; margin: 0 auto;')
    .col.p-4 
      .container-fluid

        h2.text-white.mb-4.fw-bold SALARY EARNER DEPOSIT SCHEME

        .row

          // Make a Deposit
          .col-lg-5.mb-4
            .card.h-100

              .card-header.bg-warning.text-dark
                h5.mb-0.fw-bold Make a Deposit

              .card-body
                form#depositForm(action='/deposit' method='POST')
                  //Hidden Fields
                  input(type="hidden" name="amountRedeemed" value="0")
                  input(type="hidden" name="remainingAmount" value='0') 

                  label.form-label Full Name
                  input.form-control(
                    name='fullName'
                    type='text'
                    placeholder='Enter full name'
                  )

                  .mb-3
                    label.form-label Phone Number
                    input.form-control(
                      name='phoneNumber'
                      type='tel'
                      placeholder='+256 7XX XXX XXX' 
                    )

                  .mb-3
                    label.form-label Deposit Amount (UGX)
                    input.form-control.form-control-lg(
                      type='number'
                      placeholder='50,000'
                      name= 'depositAmount'
                      min='10000'
                      step='1000'
                    )

                  .mb-3
                    label.form-label Deposit Period

                    select.form-select(name='periodMonths')
                      option(value='3') 3 Months
                      option(value='6' selected) 6 Months
                      option(value='12') 12 Months

                  .mb-3
                    label.form-label Start Date
                    input.form-control(
                      type='date'
                      name='startDate'
                    )
                    button.btn.btn-dark.w-100(
                      type='submit'
                      ) Deposit Now

          // Recent Deposits
          .col-lg-7.mb-4
            .card.h-100

              .card-header.bg-warning
                h5.mb-0.fw-bold Recent Deposits

              .card-body.p-0
                .table-responsive

                  table.table.table-hover.mb-1

                    thead.table-light
                      tr
                        th Date
                        th Name
                        th Amount
                        th Period
                        th Status
                    tbody
                      if recentDeposits.length > 0
                        each deposit in recentDeposits
                          tr
                            td= new Date(deposit.startDate).toLocaleDateString()
                            td= deposit.fullName
                            td.text-success.fw-bold= deposit.depositAmount.toLocaleString()
                            td= deposit.periodMonths + ' Months'
                            td
                              span.badge(
                                class=
                                  deposit.status === 'Active'
                                    ? 'bg-success'
                                    : deposit.status === 'Expired'
                                    ? 'bg-danger'
                                    : 'bg-secondary'
                              )= deposit.status
                      else
                        tr
                          td(colspan='5') No deposits yet
        // Customers who used up their deposit
        .card.mt-4

          .card-header.bg-warning
            h5.mb-0.fw-bold Clients who have redeemed their retainer

          .card-body
            .table-responsive

              table.table.table-hover

                thead
                  tr
                    th Name
                    th Original Deposit
                    th Amount Used
                    th Remaining
                    th Date Used
                    th Action

                tbody
                  if redeemedDeposits.length > 0
                    each deposit in redeemedDeposits
                      tr
                        td= deposit.fullName
                        td= deposit.depositAmount.toLocaleString() + ' UGX'
                        td.text-danger= deposit.amountRedeemed.toLocaleString() + ' UGX'
                        td
                          span(class=deposit.remainingAmount > 0 ? 'text-success fw-bold' : 'text-danger fw-bold')
                            = deposit.remainingAmount.toLocaleString() + ' UGX'
                        td= new Date(deposit.createdAt).toLocaleDateString()
                        td
                          form(action=`/deposit/redeem/${deposit._id}` method='POST')
                            button.btn.btn-sm.btn-outline-primary(type='submit') Replenish
                        td 
                          button.btn.btn-sm.btn-warning(data-mdb-toggle='modal' data-mdb-target=`#redeemModal-${deposit._id}`) | Redeem
                    each deposit in redeemedDeposits
                      .modal.fade(
                        id=`redeemModal-${deposit._id}`
                        tabindex='-1'
                        aria-hidden='true'
                      )

                        .modal-dialog

                          .modal-content

                            .modal-header
                              h5.modal-title Redeem Deposit

                              button.btn-close(
                                type='button'
                                data-mdb-dismiss='modal'
                              )

                            form(
                              action=`/deposits/redeem/${deposit._id}`
                              method='POST'
                            )

                              .modal-body

                                p
                                  strong Customer:
                                  |  #{deposit.fullName}

                                p
                                  strong Remaining:
                                  |  UGX #{deposit.remainingAmount.toLocaleString()}

                                .mb-3
                                  label.form-label Amount to Redeem

                                  input.form-control(
                                    type='number'
                                    name='redeemAmount'
                                    required
                                  )

                                .mb-3
                                  label.form-label Notes

                                  textarea.form-control(
                                    name='notes'
                                  )

                              .modal-footer

                                button.btn.btn-secondary(
                                  type='button'
                                  data-mdb-dismiss='modal'
                                )
                                  | Cancel

                                button.btn.btn-warning(
                                  type='submit'
                                )
                                  | Redeem
                  else
                    tr
                      td(colspan='6') No redeemed deposits
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    //- document.getElementById('depositForm').addEventListener('submit', function() {
    //-   const depositAmount = parseFloat(document.querySelector('[name="depositAmount"]').value) || 0;
    //-   // Update hidden remainingAmount field
    //-   let remainingField = document.querySelector('[name="remainingAmount"]');
    //-   if (remainingField) remainingField.value = depositAmount;
    //- });
    document.getElementById("depositForm").addEventListener("submit", function(e) {
      const phone = document.getElementById("phoneNumber").value.trim();
      const depositAmount = parseFloat(document.querySelector("[name=\"depositAmount\"]").value) || 0;
      let valid = true;

      // Clear previous errors
      document.querySelectorAll(".validation-error").forEach(function(el) { el.remove(); });
      document.querySelectorAll(".is-invalid").forEach(function(el) { el.classList.remove("is-invalid"); });

      // Phone validation — 10 digits, starts with 07
      if (!/^07\d{8}$/.test(phone)) {
        valid = false;
        showError("phoneNumber", "Phone number must be 10 digits and start with 07");
      }

      // Update hidden remainingAmount field
      const remainingField = document.querySelector("[name=\"remainingAmount\"]");
      if (remainingField) remainingField.value = depositAmount;

      if (!valid) e.preventDefault();
    });

    function showError(fieldId, message) {
      const field = document.getElementById(fieldId);
      if (!field) return;
      const error = document.createElement("div");
      error.className = "validation-error text-danger small mt-1";
      error.textContent = message;
      field.classList.add("is-invalid");
      field.parentNode.appendChild(error);
      field.addEventListener("input", function() {
        field.classList.remove("is-invalid");
        const err = field.parentNode.querySelector(".validation-error");
        if (err) err.remove();
      }, { once: true });
    }