extends layout 

block content
  .flex-grow-1.p-6.overflow-auto(style='max-width: 1000px; margin: 0 auto;')
    .col.p-4 
      .container-fluid

        h2.text-white.mb-4.fw-bold SALARY EARNER DEPOSIT SCHEME

        .row

          // Make a Deposit
          .col-lg-5.mb-4
            .card.h-100
              .card-header.bg-warning.text-dark
                h5.mb-0.fw-bold Make a Deposit
              .card-body
                form#depositForm(action='/deposit' method='POST')
                  input(type="hidden" name="amountRedeemed" value="0")
                  input(type="hidden" name="remainingAmount" value='0') 

                  label.form-label Full Name
                  input.form-control(name='fullName' type='text' placeholder='Enter full name')

                  .mb-3
                    label.form-label Phone Number
                    input#phoneNumber.form-control(name='phoneNumber' type='tel' placeholder='07XXXXXXXX')

                  .mb-3
                    label.form-label Deposit Amount (UGX)
                    input.form-control.form-control-lg(type='number' placeholder='50,000' name='depositAmount' min='10000' step='1000')

                  .mb-3
                    label.form-label Deposit Period
                    select.form-select(name='periodMonths')
                      option(value='3') 3 Months
                      option(value='6' selected) 6 Months
                      option(value='12') 12 Months

                  .mb-3
                    label.form-label Start Date
                    input.form-control(type='date' name='startDate')
                    button.btn.btn-dark.w-100(type='submit') Deposit Now

          // Recent Deposits
          .col-lg-7.mb-4
            .card.h-100
              .card-header.bg-warning
                h5.mb-0.fw-bold Recent Deposits
              .card-body.p-0
                .table-responsive
                  table.table.table-hover.mb-1
                    thead.table-light
                      tr
                        th Date
                        th Name
                        th Amount
                        th Period
                        th Status
                    tbody
                      if recentDeposits.length > 0
                        each deposit in recentDeposits
                          tr
                            td= new Date(deposit.startDate).toLocaleDateString()
                            td= deposit.fullName
                            td.text-success.fw-bold= deposit.depositAmount.toLocaleString()
                            td= deposit.periodMonths + ' Months'
                            td
                              - var statusClass = deposit.status === 'Active' ? 'bg-success' : deposit.status === 'Expired' ? 'bg-danger' : 'bg-secondary'
                              span.badge(class=statusClass)= deposit.status
                      else
                        tr
                          td(colspan='5') No deposits yet

        // Clients who have redeemed
        .card.mt-4
          .card-header.bg-warning
            h5.mb-0.fw-bold Clients who have redeemed their retainer
          .card-body
            .table-responsive
              table.table.table-hover
                thead
                  tr
                    th Name
                    th Original Deposit
                    th Total Used
                    th Remaining
                    th Last Redeemed
                    th Actions
                tbody
                  if redeemedDeposits.length > 0
                    each deposit in redeemedDeposits
                      tr
                        td= deposit.fullName
                        td.fw-bold= deposit.depositAmount.toLocaleString() + ' UGX'
                        td.text-danger.fw-bold= deposit.amountRedeemed.toLocaleString() + ' UGX'
                        td
                          - var remainClass = deposit.remainingAmount > 0 ? 'text-success fw-bold' : 'text-danger fw-bold'
                          span(class=remainClass)= deposit.remainingAmount.toLocaleString() + ' UGX'
                        td
                          if deposit.redemptions && deposit.redemptions.length > 0
                            = new Date(deposit.redemptions[deposit.redemptions.length - 1].redeemedAt).toLocaleDateString()
                          else
                            | —
                        td
                          .d-flex.gap-2
                            button.btn.btn-sm.btn-outline-primary(
                              data-bs-toggle='modal'
                              data-bs-target='#redeemModal-' + deposit._id
                            ) Redeem
                            button.btn.btn-sm.btn-outline-info(
                              data-bs-toggle='modal'
                              data-bs-target='#historyModal-' + deposit._id
                            )
                              i.fas.fa-history
                              |  History
                  else
                    tr
                      td(colspan='6') No redeemed deposits

  //- =====================
  //- MODALS — outside table and outside card, at root level
  //- =====================
  if redeemedDeposits.length > 0

    // Redeem Modals
    each deposit in redeemedDeposits
      - var redeemModalId = 'redeemModal-' + deposit._id
      .modal.fade(id=redeemModalId tabindex='-1' aria-hidden='true')
        .modal-dialog
          .modal-content
            .modal-header.bg-warning.text-dark
              h5.modal-title Redeem Deposit — #{deposit.fullName}
              button.btn-close(type='button' data-bs-dismiss='modal')
            form(action=`/deposit/redeem/${deposit._id}` method='POST')
              .modal-body
                p.mb-1
                  strong Customer:
                  |  #{deposit.fullName}
                p.mb-1
                  strong Original Deposit:
                  |  UGX #{deposit.depositAmount.toLocaleString()}
                p.mb-3
                  strong Balance Remaining:
                  span.text-success.fw-bold  UGX #{deposit.remainingAmount.toLocaleString()}
                hr
                .mb-3
                  label.form-label Amount to Redeem (UGX)
                  input.form-control(
                    type='number'
                    name='amountRedeemed'
                    min='1'
                    max=deposit.remainingAmount
                    required
                  )
                .mb-3
                  label.form-label Item / Service Description
                  input.form-control(
                    type='text'
                    name='itemDescription'
                    placeholder='e.g. Cement 50kg x 10 bags'
                  )
                .mb-3
                  label.form-label Notes
                  textarea.form-control(name='notes' rows='2' placeholder='Any additional notes...')
              .modal-footer
                button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
                button.btn.btn-warning(type='submit') Confirm Redemption

    // History Modals
    each deposit in redeemedDeposits
      - var historyModalId = 'historyModal-' + deposit._id
      .modal.fade(id=historyModalId tabindex='-1' aria-hidden='true')
        .modal-dialog.modal-lg
          .modal-content
            .modal-header.bg-info.text-white
              h5.modal-title Redemption History — #{deposit.fullName}
              button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal')
            .modal-body
              .row.mb-3
                .col-md-4
                  .card.bg-light
                    .card-body.text-center
                      small.text-muted Original Deposit
                      h5.fw-bold.mb-0= 'UGX ' + deposit.depositAmount.toLocaleString()
                .col-md-4
                  .card.bg-danger.text-white
                    .card-body.text-center
                      small Total Redeemed
                      h5.fw-bold.mb-0= 'UGX ' + deposit.amountRedeemed.toLocaleString()
                .col-md-4
                  .card.bg-success.text-white
                    .card-body.text-center
                      small Balance Remaining
                      h5.fw-bold.mb-0= 'UGX ' + deposit.remainingAmount.toLocaleString()
              hr
              if deposit.redemptions && deposit.redemptions.length > 0
                table.table.table-hover.table-bordered
                  thead.table-dark
                    tr
                      th #
                      th Date
                      th Item / Description
                      th Notes
                      th.text-end Amount (UGX)
                      th.text-end Balance After
                  tbody
                    - var runningBalance = deposit.depositAmount
                    each redemption, index in deposit.redemptions
                      - runningBalance = runningBalance - redemption.amount
                      tr
                        td= index + 1
                        td= new Date(redemption.redeemedAt).toLocaleDateString()
                        td= redemption.itemDescription || '—'
                        td= redemption.notes || '—'
                        td.text-end.text-danger.fw-bold= redemption.amount.toLocaleString()
                        td.text-end
                          - var balClass = runningBalance > 0 ? 'text-success fw-bold' : 'text-danger fw-bold'
                          span(class=balClass)= runningBalance.toLocaleString()
              else
                p.text-muted.text-center No redemption history yet
            .modal-footer
              button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Close

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    document.getElementById("depositForm").addEventListener("submit", function(e) {
      const phone = document.getElementById("phoneNumber").value.trim();
      const depositAmount = parseFloat(document.querySelector("[name=\"depositAmount\"]").value) || 0;
      let valid = true;

      document.querySelectorAll(".validation-error").forEach(function(el) { el.remove(); });
      document.querySelectorAll(".is-invalid").forEach(function(el) { el.classList.remove("is-invalid"); });

      if (!/^07\d{8}$/.test(phone)) {
        valid = false;
        showError("phoneNumber", "Phone number must be 10 digits and start with 07");
      }

      const remainingField = document.querySelector("[name=\"remainingAmount\"]");
      if (remainingField) remainingField.value = depositAmount;

      if (!valid) e.preventDefault();
    });

    function showError(fieldId, message) {
      const field = document.getElementById(fieldId);
      if (!field) return;
      const error = document.createElement("div");
      error.className = "validation-error text-danger small mt-1";
      error.textContent = message;
      field.classList.add("is-invalid");
      field.parentNode.appendChild(error);
      field.addEventListener("input", function() {
        field.classList.remove("is-invalid");
        const err = field.parentNode.querySelector(".validation-error");
        if (err) err.remove();
      }, { once: true });
    }