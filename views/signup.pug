doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NGH Sign Up
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
  style.
.signup-card.shadow
  // LOGO
  .logo.mb-3
  h4.text-center.mb-4 Create Account
  // FORM
  form(onsubmit='register(event)')
    // Username
    .mb-3
      input#username.form-control(type='text' placeholder='Username' required='')
    // Email
    .mb-3
      input#email.form-control(type='email' placeholder='Email' required='')
    // Password
    .mb-3
      input#password.form-control(type='password' placeholder='Password' required='')
    // Role
    .mb-3
      select#role.form-select
        option(value='attendant') Sales Attendant
        option(value='manager') Manager
        option(value='admin') Admin
    // Button
    button.btn.btn-ngh.w-100 Sign Up
    p.text-center.mt-3
      | Already have an account? 
      a(href='login.html') Login
script.
