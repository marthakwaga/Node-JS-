extends layout

block content
  .flex-grow-1.p-4.overflow-auto
    .container-fluid

      .d-flex.justify-content-between.align-items-center.mb-4
        h2.text-white Business Reports
        div
          button.btn.btn-danger.me-2(onclick='exportToPDF()')
            i.fas.fa-file-pdf
            |  Export PDF
          button.btn.btn-outline-light(onclick='window.print()')
            i.fas.fa-print
            |  Print

      // Range Filter Buttons
      .mb-4
        .btn-group
          a.btn(
            href='/reports?range=all'
            class=range === 'all' ? 'btn-warning' : 'btn-outline-light'
          ) All Time
          a.btn(
            href='/reports?range=weekly'
            class=range === 'weekly' ? 'btn-warning' : 'btn-outline-light'
          ) This Week
          a.btn(
            href='/reports?range=monthly'
            class=range === 'monthly' ? 'btn-warning' : 'btn-outline-light'
          ) This Month

      // Active range label
      .mb-3
        span.text-white.fw-bold
          | Showing:&nbsp;
          span.text-warning= range === 'weekly' ? 'Last 7 Days' : range === 'monthly' ? 'Last 30 Days' : 'All Time'
        span.text-white.ms-3
          | #{transactions} transaction(s)

      if error
        .alert.alert-danger= error

      // KPI Cards
      .row.mb-4
        .col-xl-3.col-md-6.mb-3
          .card.bg-success.text-white
            .card-body
              h5 Total Revenue
              h3 UGX #{totalRevenue ? totalRevenue.toLocaleString() : '0'}
        .col-xl-3.col-md-6.mb-3
          .card.bg-primary.text-white
            .card-body
              h5 Gross Profit
              h3 UGX #{grossProfit ? grossProfit.toLocaleString() : '0'}
        .col-xl-3.col-md-6.mb-3
          .card.bg-info.text-white
            .card-body
              h5 Net Profit
              h3 UGX #{netProfit ? netProfit.toLocaleString() : '0'}
        .col-xl-3.col-md-6.mb-3
          .card.bg-warning.text-white
            .card-body
              h5 Expenses
              h3 UGX #{expenses ? expenses.toLocaleString() : '0'}

      .row
        // Profit & Loss Statement
        .col-12.mb-4
          .card
            .card-header.bg-dark.text-white
              h5 Profit & Loss Statement
            .card-body
              table.table.table-bordered
                thead
                  tr
                    th Description
                    th.text-end Amount (UGX)
                tbody
                  tr
                    td Total Sales Revenue
                    td.text-end.fw-bold UGX #{totalRevenue ? totalRevenue.toLocaleString() : '0'}
                  tr
                    td Cost of Goods Sold
                    td.text-end UGX #{(totalRevenue - grossProfit).toLocaleString()}
                  tr.table-success
                    td
                      strong Gross Profit
                    td.text-end.fw-bold UGX #{grossProfit ? grossProfit.toLocaleString() : '0'}
                  tr
                    td Operating Expenses
                    td.text-end UGX #{expenses ? expenses.toLocaleString() : '0'}
                  tr.table-info
                    td
                      strong Net Profit
                    td.text-end.fw-bold UGX #{netProfit ? netProfit.toLocaleString() : '0'}

        // Low Stock Alert
        .col-lg-6.mb-4
          .card
            .card-header.bg-warning
              h5.fw-bold Low Stock Alert
            .card-body
              if lowStock && lowStock.length > 0
                table.table.table-hover
                  thead
                    tr
                      th Product
                      th Current Stock
                      th Status
                  tbody
                    each item in lowStock
                      tr
                        td= item.productName
                        td.text-danger= item.quantity + ' ' + (item.unitOfMeasure || '')
                        td
                          span.badge.bg-danger Low
              else
                p.text-muted No low stock items at the moment.

        // Recent Transactions
        .col-lg-6.mb-4
          .card
            .card-header.bg-dark.text-white
              h5.fw-bold Recent Transactions
            .card-body.p-0
              .table-responsive
                table.table.table-hover.mb-0
                  thead.table-light
                    tr
                      th Date
                      th Customer
                      th Items
                      th.text-end Amount
                  tbody
                    if sales && sales.length > 0
                      each sale in sales.slice(0, 8)
                        tr
                          td= new Date(sale.createdAt).toLocaleDateString()
                          td= sale.customerName
                          td= sale.items.length
                          td.text-end.fw-bold= 'UGX ' + sale.totalAmount.toLocaleString()
                    else
                      tr
                        td(colspan='4').text-center.text-muted No transactions found

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
  script.
    function exportToPDF() {
      window.print();
    }