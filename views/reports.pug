doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title REPORTS
  // MDB
  link(href='https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/mdb.min.css')
  link(rel='stylesheet' href='/css/nyondo.css')
  .bg-image.min-vh-100.d-flex(style="background-image: url('https://images.pexels.com/photos/4312849/pexels-photo-4312849.jpeg');")
    .mask.mask-custom.flex-grow-1(style='background-color: rgba(25, 12, 36, 0.78);')
      .d-flex.h-100

        nav.sidebar.p-3.text-white(style='width: 260px; background: rgba(242, 240, 242, 0.336);')
          .logo.mx-auto.mb-4(style="background-image: url('/images/logo.png'); width: 150px; height: 150px; background-size: contain; background-repeat: no-repeat;")
          ul.nav.flex-column
            li.nav-item
              a.nav-link.text-white(href='dashboard.html')
                i.fas.fa-tachometer-alt
                |  Dashboard
            li.nav-item
              a.nav-link.text-white(href='products.html')
                i.fas.fa-boxes
                |  Products & Stock
            li.nav-item
              a.nav-link.text-white(href='sales.html')
                i.fas.fa-shopping-cart
                |  Sales
            li.nav-item
              a.nav-link.text-white.active(href='#')
                i.fas.fa-chart-bar
                |  Reports

        .flex-grow-1.p-4.overflow-auto
          .container-fluid
            .d-flex.justify-content-between.align-items-center.mb-4
              h2.text-white Business Reports
              div
                button.btn.btn-danger.me-2(onclick='exportToPDF()')
                  i.fas.fa-file-pdf
                  |  Export PDF
                button.btn.btn-outline-light(onclick='window.print()')
                  i.fas.fa-print
                  |  Print

            if error
              .alert.alert-danger= error

            // KPI Cards
            .row.mb-4
              .col-xl-3.col-md-6.mb-3
                .card.bg-success.text-white
                  .card-body
                    h5 Total Revenue
                    h3 UGX #{totalRevenue ? totalRevenue.toLocaleString() : '0'}
              .col-xl-3.col-md-6.mb-3
                .card.bg-primary.text-white
                  .card-body
                    h5 Gross Profit
                    h3 UGX #{grossProfit ? grossProfit.toLocaleString() : '0'}
              .col-xl-3.col-md-6.mb-3
                .card.bg-info.text-white
                  .card-body
                    h5 Net Profit
                    h3 UGX #{netProfit ? netProfit.toLocaleString() : '0'}
              .col-xl-3.col-md-6.mb-3
                .card.bg-warning.text-white
                  .card-body
                    h5 Expenses
                    h3 UGX #{expenses ? expenses.toLocaleString() : '0'}

            .row
              .col-12.mb-4
                .card
                  .card-header.bg-dark.text-white
                    h5 Profit & Loss Statement
                  .card-body
                    table.table.table-bordered
                      thead
                        tr
                          th Description
                          th.text-end Amount (UGX)
                      tbody
                        tr
                          td Total Sales Revenue
                          td.text-end.fw-bold UGX #{totalRevenue ? totalRevenue.toLocaleString() : '0'}
                        tr
                          td Cost of Goods Sold
                          td.text-end UGX #{(totalRevenue - grossProfit).toLocaleString()}
                        tr.table-success
                          td
                            strong Gross Profit
                          td.text-end.fw-bold UGX #{grossProfit ? grossProfit.toLocaleString() : '0'}
                        tr
                          td Operating Expenses
                          td.text-end UGX #{expenses ? expenses.toLocaleString() : '0'}
                        tr.table-info
                          td
                            strong Net Profit
                          td.text-end.fw-bold UGX #{netProfit ? netProfit.toLocaleString() : '0'}

              .col-lg-6.mb-4
                .card
                  .card-header.bg-warning
                    h5 Low Stock Alert
                  .card-body
                    if lowStock && lowStock.length > 0
                      table.table.table-hover
                        thead
                          tr
                            th Product
                            th Current Stock
                            th Status
                        tbody
                          each item in lowStock
                            tr
                              td #{item.productName}
                              td.text-danger #{item.quantity} #{item.unitOfMeasure || ''}
                              td
                                span.badge.bg-danger Low
                    else
                      p.text-muted No low stock items at the moment.

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')

  script.
    function exportToPDF() {
      window.print();
    }