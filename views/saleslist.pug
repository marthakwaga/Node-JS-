doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo Stock - Sales List
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB' crossorigin='anonymous')
  link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css')
  link(rel='stylesheet' href='/public/css/stocklist.css')
  style.
.full-bg
  .dark-overlay.d-flex
    // Sidebar
    nav.sidebar.p-3.text-white.flex-shrink-0(style='width: 260px;')
      .logo.mx-auto.mb-4
      ul.nav.flex-column
        li.nav-item
          a.nav-link(href='manager-dashboard.html')
            i.fas.fa-tachometer-alt
            |  Dashboard
        li.nav-item
          a.nav-link(href='stocklist.html')
            i.fas.fa-list
            |  Stock List
        li.nav-item
          a.nav-link.active(href='saleslist.html')
            i.fas.fa-shopping-cart
            |  Sales List
        li.nav-item
          a.nav-link(href='products.html')
            i.fas.fa-boxes
            |  Products &amp; Stock
        li.nav-item
          a.nav-link(href='stock-registration.html')
            i.fas.fa-truck-loading
            |  Stock In
        li.nav-item
          a.nav-link(href='orders.html')
            i.fas.fa-plus-circle
            |  New Sale
        li.nav-item
          a.nav-link(href='deposits.html')
            i.fas.fa-hand-holding-usd
            |  Deposit Scheme
        li.nav-item
          a.nav-link(href='suppliers.html')
            i.fas.fa-users
            |  Suppliers
        li.nav-item
          a.nav-link(href='transport.html')
            i.fas.fa-truck
            |  Transport
        li.nav-item
          a.nav-link(href='reports.html')
            i.fas.fa-chart-bar
            |  Reports
      button.btn.btn-outline-warning.w-100.mt-4(onclick='logout()') Logout
    // Main Content
    .flex-grow-1.p-4.overflow-auto
      .d-flex.justify-content-between.align-items-center.mb-4
        h1.text-white.fw-bold &#x1F4B0; Sales List
        a.btn.btn-success.btn-lg(href='orders.html')
          i.fas.fa-plus
          |  New Sale
      // Filters
      .row.mb-4
        .col-md-5
          input#searchInput.form-control.form-control-lg(type='text' placeholder='🔍 Search customer, order ID...' onkeyup='filterSales()')
        .col-md-3
          select#statusFilter.form-select.form-select-lg(onchange='filterSales()')
            option(value='') All Sales
            option(value='paid') Paid
            option(value='pending') Pending
        .col-md-4
          .input-group
            span.input-group-text Date From
            input#dateFrom.form-control(type='date' onchange='filterSales()')
      // Sales Table
      .table-responsive
        table#salesTable.table.table-hover.align-middle.text-white
          thead.table-dark
            tr
              th Date
              th Order ID
              th Customer
              th Items
              th Total Amount
              th Payment Status
              th Transport
              th Actions
          tbody#salesBody
            // Populated by JavaScript
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js' integrity='sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI' crossorigin='anonymous')
script.
  // Sample Sales Data (Replace with fetch from database later)
  let salesData = [
  {
  id: 1,
  date: "2026-05-04",
  orderId: "ORD-8925",
  customer: "John Mukasa",
  items: "150 Bags Cement + 20 Iron Bars",
  amount: 4280000,
  status: "paid",
  transport: "Free"
  },
  {
  id: 2,
  date: "2026-05-04",
  orderId: "ORD-8924",
  customer: "Maria Namutebi",
  items: "50 Iron Sheets",
  amount: 4750000,
  status: "pending",
  transport: "30,000"
  },
  {
  id: 3,
  date: "2026-05-03",
  orderId: "ORD-8923",
  customer: "David Okello",
  items: "300 Bags Cement",
  amount: 8400000,
  status: "paid",
  transport: "Free"
  },
  {
  id: 4,
  date: "2026-05-03",
  orderId: "ORD-8922",
  customer: "Amina Nakato",
  items: "8 Wheelbarrows",
  amount: 600000,
  status: "paid",
  transport: "30,000"
  }
  ];
  function renderSales(data) {
  const tbody = document.getElementById('salesBody');
  tbody.innerHTML = '';
  data.forEach(sale => {
  const statusClass = sale.status === 'paid' ? 'paid' : 'pending';
  const statusText = sale.status === 'paid' ? '✅ Paid' : '⏳ Pending';
  const row = document.createElement('tr');
  row.innerHTML = `
  <td>${sale.date}</td>
  <td><strong>${sale.orderId}</strong></td>
  <td>${sale.customer}</td>
  <td>${sale.items}</td>
  <td class="fw-bold">UGX ${sale.amount.toLocaleString('en-US')}</td>
  <td><span class="badge ${statusClass}">${statusText}</span></td>
  <td>${sale.transport}</td>
  <td>
  <button class="btn btn-sm btn-outline-info me-1" onclick="viewReceipt(${sale.id})">
  <i class="fas fa-receipt"></i>
  </button>
  <button class="btn btn-sm btn-outline-success" onclick="printInvoice(${sale.id})">
  <i class="fas fa-print"></i>
  </button>
  </td>
  `;
  tbody.appendChild(row);
  });
  }
  function filterSales() {
  const searchTerm = document.getElementById('searchInput').value.toLowerCase();
  const status = document.getElementById('statusFilter').value;
  let filtered = salesData.filter(sale => {
  const matchesSearch = sale.customer.toLowerCase().includes(searchTerm) ||
  sale.orderId.toLowerCase().includes(searchTerm) ||
  sale.items.toLowerCase().includes(searchTerm);
  const matchesStatus = !status || sale.status === status;
  return matchesSearch && matchesStatus;
  });
  renderSales(filtered);
  }
  function viewReceipt(id) {
  const sale = salesData.find(s => s.id === id);
  if (sale) {
  alert(`📄 Receipt for ${sale.orderId}\\n\nCustomer: ${sale.customer}\nTotal: UGX ${sale.amount.toLocaleString()}\nStatus: ${sale.status.toUpperCase()}\n\n(Full receipt view coming soon)`);
  }
  }
  function printInvoice(id) {
  alert(`🖨️ Printing Invoice for Order #${id}... (Demo)`);
  }
  function logout() {
  if (confirm("Logout from Nyondo Stock?")) {
  window.location.href = "login.html";
  }
  }
  // Initialize page
  window.onload = () => renderSales(salesData);
